---
const currentPath = Astro.url.pathname;

// Verificar sesiones desde el servidor (más seguro y sin parpadeos)
const isAdmin = Astro.cookies.has('admin_session');
const isEmployee = Astro.cookies.has('session');
---

<nav class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <span class="logo-text">CHECADOR</span><span class="logo-dot">.</span>
    </div>
    
    <div class="nav-links">
      {/* 1. ENLACES DE ADMINISTRADOR (Solo si hay admin_session) */}
      {isAdmin && (
        <div class="admin-links-group">
          <a href="/admin/scanner" class={currentPath === "/admin/scanner" ? "active" : ""}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <span>Escáner</span>
          </a>
          <a href="/admin/hoy" class={currentPath === "/admin/hoy" ? "active" : ""}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Hoy</span>
          </a>
          <a href="/admin/reportes" class={currentPath === "/admin/reportes" ? "active" : ""}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
            <span>Reportes</span>
          </a>
          <a href="/admin/empleados" class={currentPath === "/admin/empleados" ? "active" : ""}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Personal</span>
          </a>
        </div>
      )}

      {/* 2. ENLACES DE EMPLEADO (Solo si NO es admin y tiene sesión) */}
      {isEmployee && !isAdmin && (
        <a href="/credential" class={currentPath === "/credential" ? "active" : ""}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><circle cx="12" cy="10" r="3"/><path d="M7 20c0-2.5 2-4.5 5-4.5s5 2 5 4.5"/></svg>
          <span>Mi Gafete</span>
        </a>
      )}

      {/* 3. ENLACE PÚBLICO (Solo si no hay nadie logueado) */}
      {!isAdmin && !isEmployee && (
        <a href="/" class={currentPath === "/" ? "active" : ""}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Inicio</span>
        </a>
      )}

      {/* 4. BOTÓN SALIR (Si hay cualquier sesión) */}
      {(isAdmin || isEmployee) && (
        <button id="btn-logout-any" class="btn-logout">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Salir</span>
        </button>
      )}
    </div>
  </div>
</nav>

<script>
  // Lógica de Logout (Cierra ambas sesiones por seguridad)
  document.getElementById('btn-logout-any')?.addEventListener('click', () => {
    document.cookie = "admin_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    document.cookie = "session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    window.location.href = '/';
  });
</script>

<style>
  .navbar {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 0.6rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo { font-weight: 800; font-size: 1.35rem; color: #1e293b; letter-spacing: -0.5px; }
  .logo-dot { color: #3b82f6; margin-left: 1px; }

  .nav-links { display: flex; align-items: center; gap: 0.5rem; }
  .admin-links-group { display: flex; align-items: center; gap: 0.5rem; }

  .nav-links a, .btn-logout {
    text-decoration: none;
    color: #64748b;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 8px 16px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
  }

  .nav-links a:hover:not(.active) { background: #f8fafc; color: #1e293b; }
  .nav-links a.active { background: #eff6ff; color: #3b82f6; }
  .btn-logout { color: #ef4444 !important; font-weight: 700; }
  .btn-logout:hover { background: #fef2f2; }

  @media (max-width: 900px) {
    .nav-links span { display: none; }
    .nav-links a { padding: 10px; }
  }
</style>
