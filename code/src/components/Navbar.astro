---
const currentPath = Astro.url.pathname;

// Verificar sesiones desde el servidor
const isAdmin = Astro.cookies.has('admin_session');
const isEmployee = Astro.cookies.has('session');

// Determinar el enlace del logo
const logoLink = isAdmin ? "/admin/dashboard" : "/";
---

<nav class="navbar">
  <div class="nav-container">
    <a href={logoLink} class="nav-logo">
      <span class="logo-text">CHECADOR</span><span class="logo-dot">.</span>
    </a>
    
    <div class="nav-links">
      {/* Solo mostramos el Dashboard si NO estamos ya en el dashboard y somos admin */}
      {isAdmin && currentPath !== "/admin/dashboard" && (
        <a href="/admin/dashboard" class="dashboard-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Dashboard</span>
        </a>
      )}

      {/* 2. ENLACES DE EMPLEADO (Solo si NO es admin y tiene sesión) */}
      {isEmployee && !isAdmin && (
        <a href="/credential" class={currentPath === "/credential" ? "active" : ""}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><circle cx="12" cy="10" r="3"/><path d="M7 20c0-2.5 2-4.5 5-4.5s5 2 5 4.5"/></svg>
          <span>Mi Gafete</span>
        </a>
      )}

      {/* 4. BOTÓN SALIR (Si hay cualquier sesión) */}
      {(isAdmin || isEmployee) && (
        <button id="btn-logout-any" class="btn-logout">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Salir</span>
        </button>
      )}
    </div>
  </div>
</nav>

<script>
  // Lógica de Logout
  document.getElementById('btn-logout-any')?.addEventListener('click', () => {
    document.cookie = "admin_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    document.cookie = "session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    window.location.href = '/';
  });
</script>

<style>
  .navbar {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 0.6rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo { font-weight: 800; font-size: 1.35rem; color: #1e293b; letter-spacing: -0.5px; text-decoration: none; }
  .logo-dot { color: #3b82f6; margin-left: 1px; }

  .nav-links { display: flex; align-items: center; gap: 0.5rem; }

  .nav-links a, .btn-logout {
    text-decoration: none;
    color: #64748b;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 8px 16px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
  }

  .nav-links a:hover:not(.active) { background: #f8fafc; color: #1e293b; }
  .nav-links a.active { background: #eff6ff; color: #3b82f6; }
  .btn-logout { color: #ef4444 !important; font-weight: 700; }
  .btn-logout:hover { background: #fef2f2; }

  .dashboard-link {
    color: #4a90e2 !important;
    background: #f0f7ff;
  }

  @media (max-width: 600px) {
    .nav-links span { display: none; }
    .nav-links a, .btn-logout { padding: 10px; }
    .nav-logo .logo-text { font-size: 1.1rem; }
  }
</style>
