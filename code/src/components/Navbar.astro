---
const logoLink = "/"; // Por defecto al inicio, JS lo cambiará si es admin
---

<nav class="navbar">
  <div class="nav-container">
    <a href={logoLink} class="nav-logo" id="nav-logo-link">
      <img src="/logonavbar.png" alt="Logo" class="navbar-logo-img logo-light" />
      <img src="/logonavbar_dark.png" alt="Logo" class="navbar-logo-img logo-dark" />
    </a>

    <div class="nav-welcome-text">
      Bienvenido al control de asistencia de <span>Einsur Global</span>
    </div>

    <div class="nav-links">
      {/* Botón de Modo Oscuro */}
      <button id="theme-toggle" class="btn-theme-toggle" aria-label="Cambiar tema">
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      {/* Botón Dashboard (Oculto por defecto) */}
      <a
        href="/admin/dashboard"
        id="nav-admin-link"
        class="dashboard-link"
        style="display: none;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="3" y="3" width="7" height="7"></rect><rect
            x="14"
            y="3"
            width="7"
            height="7"></rect><rect x="14" y="14" width="7" height="7"
          ></rect><rect x="3" y="14" width="7" height="7"></rect>
        </svg>
        <span>Dashboard</span>
      </a>

      {/* Botón Mi Gafete (Oculto por defecto) */}
      <a href="/credential" id="nav-employee-link" style="display: none;">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><circle
            cx="12"
            cy="10"
            r="3"></circle><path d="M7 20c0-2.5 2-4.5 5-4.5s5 2 5 4.5"></path>
        </svg>
        <span>Mi Gafete</span>
      </a>

      {/* Botón Salir (Oculto por defecto) */}
      <button id="btn-logout-any" class="btn-logout" style="display: none;">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline
            points="16 17 21 12 16 7"></polyline><line
            x1="21"
            y1="12"
            x2="9"
            y2="12"></line>
        </svg>
        <span>Salir</span>
      </button>
    </div>
  </div>
</nav>

<script>
  function updateNavbar() {
    const isAdmin = document.cookie
      .split(";")
      .some((item) => item.trim().startsWith("admin_session="));
    const isEmployee = document.cookie
      .split(";")
      .some((item) => item.trim().startsWith("session="));
    const currentPath = window.location.pathname;

    const adminLink = document.getElementById("nav-admin-link");
    const employeeLink = document.getElementById("nav-employee-link");
    const logoutBtn = document.getElementById("btn-logout-any");
    const logoLink = document.getElementById(
      "nav-logo-link",
    ) as HTMLAnchorElement;

    if (isAdmin) {
      if (adminLink && currentPath !== "/admin/dashboard")
        adminLink.style.display = "flex";
      if (logoLink) logoLink.href = "/admin/dashboard";
      if (logoutBtn) logoutBtn.style.display = "flex";
    } else if (isEmployee) {
      if (employeeLink) {
        employeeLink.style.display = "flex";
        if (currentPath === "/credential") employeeLink.classList.add("active");
      }
      if (logoutBtn) logoutBtn.style.display = "flex";
    }
  }

  updateNavbar();

  // Lógica de Logout
  document.getElementById("btn-logout-any")?.addEventListener("click", () => {
    document.cookie =
      "admin_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    document.cookie =
      "session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    window.location.href = "/";
  });
</script>

<style>
  .navbar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    padding: 0.3rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: auto !important;
    z-index: 1000;
    margin: 0 !important;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .nav-container {
    max-width: 100%;
    margin: 0;
    padding: 0 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .navbar-logo-img {
    height: 58px;
    width: auto;
    object-fit: contain;
  }
  .logo-dark {
    display: none !important;
  }
  html[data-theme="dark"] .logo-light {
    display: none !important;
  }
  html[data-theme="dark"] .logo-dark {
    display: block !important;
  }

  .nav-welcome-text {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.1rem;
    color: var(--title-dark);
    font-weight: 800;
    pointer-events: none;
    white-space: nowrap;
    letter-spacing: -0.5px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links a,
  .btn-logout {
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 8px 16px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: "Inter", sans-serif;
  }

  .btn-theme-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 8px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .btn-theme-toggle:hover {
    background: var(--bg-tertiary);
    color: var(--text-main);
  }

  .nav-links a:hover:not(.active) {
    background: var(--bg-tertiary);
    color: var(--text-main);
  }
  .nav-links a.active {
    background: var(--bg-primary);
    color: var(--primary);
  }
  .btn-logout {
    color: #ef4444 !important;
    font-weight: 700;
  }
  .btn-logout:hover {
    background: #fef2f2;
  }

  .dashboard-link {
    color: #4a90e2 !important;
    background: #f0f7ff;
  }
  
  html[data-theme="dark"] .dashboard-link {
    color: #93c5fd !important;
    background: #1e3a8a !important;
  }

  @media (max-width: 1024px) {
    .nav-welcome-text {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .nav-links span {
      display: none;
    }
    .nav-links a,
    .btn-logout {
      padding: 10px;
    }
    .navbar-logo-img {
      height: 28px;
    }
  }
</style>
