---
interface Props {
	title?: string;
	hideNavbar?: boolean;
}

import Navbar from '../components/Navbar.astro';

const { title, hideNavbar = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isLoginPage = currentPath === "/" || 
                    currentPath === "/index.html" || 
                    currentPath === "/admin/login" || 
                    currentPath === "/admin/login.html";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="apple-touch-icon" href="/favicon.ico?v=3" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<title>{title || 'Sistema de Asistencia'}</title>
	</head>
	<body class={(isLoginPage || hideNavbar) ? "login-body" : ""}>
		{!isLoginPage && !hideNavbar && <Navbar />}
		<slot />
	</body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

	html, body {
		margin: 0 !important;
		width: 100% !important;
		min-width: 100% !important;
		min-height: 100vh;
    background: #f1f5f9;
    font-family: 'Inter', sans-serif;
    color: #1e293b;
    overflow-x: hidden;
    display: block;
    padding: 0;
	}

  body:not(.login-body) {
    padding-top: 64px; /* Solo para páginas con navbar */
  }

  /* Global Design Tokens based on reference image (Exact Colors) */
  :root {
    --primary: #4A90E2;       /* El azul vibrante de "Asistencia" */
    --primary-dark: #357ABD;
    --title-dark: #273469;    /* El azul marino denso de "Registro de" */
    --text-muted: #64748b;
    --border-radius: 12px;
  }

  h1 {
    display: block;
    width: 100%;
    text-align: center;
    font-weight: 900;
    font-size: 3.2rem;
    letter-spacing: -0.04em;
    margin: 2rem auto 3rem auto;
    line-height: 1.2;
    background: linear-gradient(to right, #273469 0%, #4A90E2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }



  .btn-premium {
    min-width: 200px;
    height: 52px;
    border-radius: 14px;
    font-weight: 800;
    font-size: 1.1rem;
    transition: all 0.2s ease-in-out;
    cursor: pointer;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    box-sizing: border-box;
  }

  .btn-premium.primary {
    background: #4A90E2;
    color: white;
    box-shadow: 0 8px 20px -4px rgba(74, 144, 226, 0.4);
  }

  .btn-premium.outline {
    background: white;
    color: #64748b;
    border: 2px solid #e2e8f0;
  }

  /* Card estilo foto */
  .card-premium {
    background: white;
    border-radius: 24px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    border: 1px solid #f8fafc;
    padding: 3.5rem;
  }
</style>
