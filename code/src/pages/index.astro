---
import Layout from "../layouts/Layout.astro";

// Redirigir si ya hay sesión
const session = Astro.cookies.get("session");
if (session) {
  return Astro.redirect("/credential");
}

// Prevenir caché para que el botón atrás siempre valide la sesión
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
---

<Layout title="Acceso de Empleados">
  <main class="contenedor-principal">
    <div class="login-wrapper">
      {/* Panel Izquierdo: Foto (Oculto en móvil) */}
      <div class="photo-panel">
        <div class="photo-card">
          <img
            src="/images/login-photo.png"
            alt="Industrial Office"
            class="login-image"
          />
          <div class="photo-overlay">
            <div class="overlay-content"></div>
          </div>
        </div>
      </div>

      {/* Panel Derecho: Login */}
      <div class="card-premium login-card">
        <div class="logo-circle">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="icon-logo"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
            ></path>
          </svg>
        </div>

        <h1 class="main-title">Acceso</h1>
        <p class="subtitle">Ingresa tus credenciales para acceder</p>

        <form id="login-form" class="login-form">
          <div class="input-container">
            <svg
              class="input-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
              ></path><circle cx="12" cy="7" r="4"></circle>
            </svg>
            <input
              type="text"
              name="employee_id"
              placeholder="ID Empleado"
              required
            />
          </div>

          <div class="input-container">
            <svg
              class="input-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
              ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <input
              type="password"
              name="password"
              placeholder="Contraseña"
              required
            />
          </div>

          <button
            type="submit"
            class="btn-premium primary"
            style="width: 100%; height: 52px; border-radius: 14px; font-weight: 800; font-size: 1.1rem; background: #4A90E2; color: white; border: none; cursor: pointer; box-shadow: 0 8px 20px -4px rgba(74, 144, 226, 0.4); margin-top: 10px;"
          >
            Iniciar Sesión
          </button>
        </form>
        <div class="error-container">
          <div id="error-message" class="error-message"></div>
        </div>

        <div class="login-footer">
          <a href="/admin/login" class="admin-link">Acceso Administrativo</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document
    .getElementById("login-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(
        new FormData(e.target as HTMLFormElement),
      );
      const response = await fetch("/api/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        window.location.replace("/credential");
      } else {
        const errorDiv = document.getElementById("error-message");
        if (errorDiv) {
          errorDiv.textContent = "ID de empleado o contraseña incorrectos";
          errorDiv.classList.add("visible");
        }
      }
    });

  // Limpiar error al escribir
  document.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', () => {
      document.getElementById("error-message")?.classList.remove("visible");
    });
  });
</script>

<style>
  .contenedor-principal {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
    padding: 2rem;
  }

  .login-wrapper {
    display: flex;
    gap: 0;
    align-items: stretch;
    max-width: 1000px;
    width: 100%;
    justify-content: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  /* Photo Panel Styling */
  .photo-panel {
    flex: 0 0 500px; /* Ancho fijo de 500px */
    width: 500px;
    display: flex;
  }

  .photo-card {
    position: relative;
    width: 100%;
    border-radius: 0;
    overflow: hidden;
  }

  .login-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
  }

  .photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(39, 52, 105, 0.9));
    padding: 3rem 2rem;
    color: white;
  }

  .overlay-content h2 {
    margin: 0;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 2px;
  }
  .overlay-content p {
    margin: 5px 0 0 0;
    opacity: 0.8;
    font-weight: 500;
  }

  /* Login Card Styling */
  .login-card {
    flex: 0 0 500px; /* Ancho fijo de 500px */
    width: 500px;
    max-width: 500px;
    text-align: center;
    padding: 4rem !important;
    background: white;
    border-radius: 0;
    box-shadow: none;
    box-sizing: border-box; /* Crucial para que el padding no estire la tarjeta */
  }

  .logo-circle {
    margin: 0 auto 1.5rem auto;
    width: 64px;
    height: 64px;
    background: #eff6ff;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a90e2;
  }
  .main-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .subtitle {
    color: #64748b;
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .input-container {
    position: relative;
    width: 100%;
  }
  .input-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
  }
  input {
    width: 100%;
    padding: 14px 16px 14px 48px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 1rem;
    box-sizing: border-box;
  }
  input:focus {
    border-color: #4a90e2;
    outline: none;
  }

  .error-container {
    position: relative;
    height: 0;
    width: 100%;
    z-index: 10;
  }

  .error-message {
    position: absolute;
    top: 10px;
    left: 0;
    right: 0;
    color: #ef4444;
    font-size: 0.85rem;
    font-weight: 700;
    display: none;
    padding: 0.6rem;
    background: #fef2f2;
    border-radius: 8px;
    border: 1px solid #fee2e2;
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.1);
  }

  .error-message.visible {
    display: block;
    animation: shake 0.4s ease-in-out;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }

  .login-footer {
    margin-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
    padding-top: 1.5rem;
  }
  .admin-link {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Responsive Logic */
  @media (max-width: 1000px) {
    .login-wrapper {
      width: 100%;
      max-width: 500px;
      flex-direction: column;
    }
    .photo-panel {
      display: none;
    }
    .login-card {
      width: 100%;
      max-width: 100%;
      flex: 1;
    }
  }

  @media (max-width: 425px) {
    .contenedor-principal {
      padding: 1rem;
      align-items: flex-start; /* Subir la tarjeta */
      padding-top: 8vh; /* Espacio desde arriba */
    }
    .login-card {
      padding: 2.5rem !important;
    }
    .main-title {
      font-size: 2.2rem;
    }
  }

  @media (max-width: 375px) {
    .login-card {
      padding: 2rem !important;
    }
    .main-title {
      font-size: 2rem;
    }
    .subtitle {
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 320px) {
    .login-card {
      padding: 1.5rem !important;
    }
    .main-title {
      font-size: 1.8rem;
    }
    .logo-circle {
      width: 50px;
      height: 50px;
      margin-bottom: 1rem;
    }
  }
</style>
