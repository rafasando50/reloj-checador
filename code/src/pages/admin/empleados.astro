---
import Layout from "../../layouts/Layout.astro";
---

<script>
  // Verificar sesión admin
  if (!document.cookie.split(';').some((item) => item.trim().startsWith('admin_session='))) {
    window.location.replace("/admin/login");
  }

  // Cargar datos dinámicamente
  async function cargarDatos(forceReloadCompanies = false) {
    const showInactive = (document.getElementById("check-inactive") as HTMLInputElement)?.checked;
    const company = document.querySelector(".tab-btn.active")?.getAttribute("data-company") || "all";
    
    try {
      // Cargar Empresas si es la primera vez o si se fuerza la recarga
      const optionsContainer = document.getElementById("company-options");
      if (forceReloadCompanies || (optionsContainer && optionsContainer.children.length <= 1)) {
        const resComp = await fetch("/api/companies.php");
        const companies = await resComp.json();
        const tabsContainer = document.querySelector(".company-tabs");
        
        // Limpiar para evitar duplicados, pero mantener "Todos" en los tabs
        if (optionsContainer) optionsContainer.innerHTML = '';
        
        // Mantener solo el botón "Todos" en los tabs
        const btnTodos = tabsContainer?.querySelector('[data-company="all"]');
        if (tabsContainer) {
          tabsContainer.innerHTML = '';
          if (btnTodos) tabsContainer.appendChild(btnTodos);
        }
        
        companies.forEach(c => {
          // Opción en el select del modal
          const opt = document.createElement("div");
          opt.className = "option";
          opt.dataset.value = c.name;
          opt.textContent = c.name;
          opt.onclick = () => seleccionarEmpresa(c.name);
          optionsContainer?.appendChild(opt);

          // Botón en los tabs
          const btn = document.createElement("button");
          btn.className = "tab-btn" + (company === c.name ? " active" : "");
          btn.dataset.company = c.name;
          btn.textContent = c.name;
          btn.onclick = () => {
            document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            cargarDatos();
          };
          tabsContainer?.appendChild(btn);
        });
      }

      // Cargar Usuarios
      const resUsers = await fetch(`/api/admin/users.php?showInactive=${showInactive}&company=${company}`);
      const users = await resUsers.json();
      const rowsContainer = document.getElementById("employee-rows");
      if (rowsContainer) {
        rowsContainer.innerHTML = users.map(u => `
          <div class="employee-row ${u.active ? "" : "row-inactive"}" 
               style="display: grid; grid-template-columns: 2.5fr 1fr 1.5fr 1fr 1.5fr; align-items: center; padding: 1.25rem 2rem; gap: 1rem; border-bottom: 1px solid #f1f5f9;">
            <div class="col-name" style="text-align: left;">
              <div class="user-info" style="display: flex; align-items: center; gap: 10px;">
                <span class="user-name" style="font-weight: 700; color: #1e293b; font-size: 1rem;">${u.full_name}</span>
                ${!u.active ? '<span class="badge-inactive" style="background: #fee2e2; color: #ef4444; font-size: 0.65rem; font-weight: 800; padding: 3px 8px; border-radius: 6px; margin-left: 8px;">Inactivo</span>' : ''}
              </div>
            </div>
            <div class="col-id" style="text-align: center;"><code class="id-code" style="background: #f1f5f9; padding: 4px 10px; border-radius: 8px; font-family: monospace; font-size: 0.85rem; color: #475569;">${u.employee_id}</code></div>
            <div class="col-dept" style="text-align: left; color: #475569;">${u.department || "-"}</div>
            <div class="col-company" style="text-align: center;">
              <span class="tag-${(u.company || 'default').toLowerCase()}">
                ${u.company || "-"}
              </span>
            </div>
            <div class="col-actions" style="text-align: center;">
              <div class="actions-cell" style="display: flex; gap: 10px; justify-content: center;">
                <button class="btn-action edit btn-edit-trigger" onclick='editarUsuario(${JSON.stringify(u)})'>
                  Editar
                </button>
                ${u.active ? `
                  <button class="btn-action deactivate" onclick="confirmarDesactivar(${u.id}, '${u.full_name}')">
                    Desactivar
                  </button>
                ` : `
                  <button class="btn-action reactivate" onclick="reactivarUsuario(${u.id})">
                    Reactivar
                  </button>
                `}
              </div>
            </div>
          </div>
        `).join("");
      }
    } catch (e) {
      console.error("Error al cargar datos:", e);
    }
  }

  function seleccionarEmpresa(name) {
    const hiddenInput = document.getElementById('company-hidden') as HTMLInputElement;
    if (hiddenInput) hiddenInput.value = name;
    const labelEl = document.getElementById('selected-company-label');
    if (labelEl) labelEl.innerText = name;
    document.querySelectorAll('#company-options .option').forEach(o => o.classList.remove('selected'));
    document.querySelector(`#company-options .option[data-value="${name}"]`)?.classList.add('selected');
    document.getElementById('company-options')?.classList.remove('active');
    document.getElementById('company-trigger')?.classList.remove('active');
  }

  // Script unificado para modales y acciones
  const modal = document.getElementById("modal");
  const confirmModal = document.getElementById("confirm-modal");
  const userForm = document.getElementById("user-form") as HTMLFormElement;

  // Funciones Globales
  (window as any).cargarDatos = cargarDatos;
  (window as any).seleccionarEmpresa = seleccionarEmpresa;

  (window as any).editarUsuario = (user) => {
    (document.getElementById("user-id") as HTMLInputElement).value = user.id;
    (document.getElementById("field-name") as HTMLInputElement).value = user.full_name;
    (document.getElementById("field-id") as HTMLInputElement).value = user.employee_id;
    (document.getElementById("field-dept") as HTMLInputElement).value = user.department;
    seleccionarEmpresa(user.company);
    document.getElementById("modal-title").textContent = "Editar Empleado";
    modal?.classList.add("active");
  };

  (window as any).confirmarDesactivar = (id, name) => {
    const nameEl = document.getElementById("confirm-user-name");
    if (nameEl) nameEl.textContent = name;
    (document.getElementById("execute-delete") as any).dataset.id = id;
    confirmModal?.classList.add("active");
  };

  (window as any).reactivarUsuario = async (id) => {
    const res = await fetch(`/api/admin/reactivate-user.php?id=${id}`, { method: "POST" });
    if (res.ok) cargarDatos();
  };

  document.addEventListener("DOMContentLoaded", () => {
    cargarDatos();
    
    // Configurar eventos de modales y filtros
    document.getElementById("check-inactive")?.addEventListener("change", cargarDatos);
    
    // Evento para el tab estático "Todos"
    const btnTodos = document.querySelector('.tab-btn[data-company="all"]');
    btnTodos?.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      btnTodos.classList.add("active");
      cargarDatos();
    });
    
    document.getElementById("open-modal")?.addEventListener("click", () => {
      userForm.reset();
      (document.getElementById("user-id") as HTMLInputElement).value = "";
      seleccionarEmpresa("Einsur"); // Resetear el selector al valor por defecto
      document.getElementById("modal-title").textContent = "Nuevo Empleado";
      modal?.classList.add("active");
    });

    document.getElementById("close-modal")?.addEventListener("click", () => modal?.classList.remove("active"));
    document.getElementById("cancel-confirm")?.addEventListener("click", () => confirmModal?.classList.remove("active"));

    // --- Lógica del Custom Select (Empresas) ---
    const trigger = document.getElementById('company-trigger');
    const optionsMenu = document.getElementById('company-options');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      optionsMenu?.classList.toggle('active');
      trigger?.classList.toggle('active');
    });

    // Cerrar al hacer clic fuera
    window.addEventListener('click', () => {
      optionsMenu?.classList.remove('active');
      trigger?.classList.remove('active');
    });
    
    // Formulario Usuario
    userForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(userForm));
      const res = await fetch("/api/admin/create-user.php", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        modal?.classList.remove("active");
        cargarDatos();
      }
    });

    // Ejecutar Desactivación
    document.getElementById("execute-delete")?.addEventListener("click", async () => {
      const btn = document.getElementById("execute-delete") as HTMLElement;
      const id = btn.dataset.id;
      if (!id) return;
      
      const res = await fetch(`/api/admin/deactivate-user.php?id=${id}`, { method: "POST" });
      if (res.ok) {
        confirmModal?.classList.remove("active");
        cargarDatos();
      }
    });

    // Lógica de Empresas
    const companyModal = document.getElementById("company-modal");
    document.getElementById("open-company-modal")?.addEventListener("click", () => companyModal?.classList.add("active"));
    document.getElementById("close-company-modal")?.addEventListener("click", () => companyModal?.classList.remove("active"));
    
    document.getElementById("save-company")?.addEventListener("click", async () => {
      const nameInput = document.getElementById("new-company-name") as HTMLInputElement;
      const name = nameInput.value;
      if (!name) return;
      const res = await fetch(`/api/admin/companies.php?name=${encodeURIComponent(name)}`, { method: "POST" });
      if (res.ok) {
        nameInput.value = "";
        companyModal?.classList.remove("active");
        cargarDatos();
      }
    });
  });
</script>

<Layout title="Gestión de Personal">
  <main class="content">
    <div class="card-premium management-card">
      <h1 class="main-title gradient-text">
        Empleados
      </h1>

      <div class="filters-bar">
        <div class="left-filters">
          <div class="company-tabs">
            <button class="tab-btn active" data-company="all">Todos</button>
            {/* Las empresas se cargarán dinámicamente */}
          </div>

          <label class="toggle-inactive">
            <input type="checkbox" id="check-inactive" onchange="cargarDatos()" />
            <div class="switch"></div>
            <span>Mostrar inactivos</span>
          </label>
        </div>

        <div class="action-buttons">
          <button
            id="open-company-modal"
            class="btn-premium outline btn-main-action"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
            Empresa
          </button>
          <button
            id="open-modal"
            class="btn-premium primary btn-main-action"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Empleado
          </button>
        </div>
      </div>

      <div class="employee-list-container">
        <div class="employee-header">
          <div class="col-name">Nombre</div>
          <div class="col-id">ID</div>
          <div class="col-dept">Depto</div>
          <div class="col-company">Empresa</div>
          <div class="col-actions">Acciones</div>
        </div>
        <div id="employee-rows" class="employee-rows">
          {/* Los empleados se cargarán dinámicamente */}
        </div>
      </div>
    </div>
  </main>

  {/* Los Modales se mantienen igual */}
  <div id="modal" class="modal">
    <div class="modal-content card-premium" style="border-radius: 0; padding: 4rem !important;">
      <h1 id="modal-title" style="font-size: 40px; font-weight: 800; text-align: center; margin-bottom: 3.5rem;">Nuevo Empleado</h1>
      <form id="user-form" class="modal-form">
        <input type="hidden" name="id" id="user-id" />
        <div class="form-grid">
          <div class="input-container full-width">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <input type="text" name="full_name" id="field-name" placeholder="Nombre Completo" required />
          </div>
          <div class="input-container">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
            <input type="text" name="employee_id" id="field-id" placeholder="ID Empleado" required />
          </div>
          <div class="input-container">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input type="password" name="password" id="field-pass" placeholder="Contraseña" />
          </div>
          <div class="input-container full-width">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-3-3.87"/><path d="M9 21v-2a4 4 0 0 1 3-3.87"/><circle cx="9" cy="7" r="4"/></svg>
            <input type="text" name="department" id="field-dept" placeholder="Departamento" />
          </div>
          <div class="input-container full-width">
            <div class="custom-select-wrapper">
              <input type="hidden" name="company" id="company-hidden" value="Einsur" />
              <div class="custom-select-trigger" id="company-trigger">
                <span id="selected-company-label">Einsur</span>
                <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
              <div class="custom-options" id="company-options">
                <div class="option selected" data-value="Einsur">Einsur</div>
                {/* Cargado dinámicamente */}
              </div>
            </div>
          </div>
        </div>
        <div class="form-actions">
          <button type="button" id="close-modal" class="btn-premium outline">Cancelar</button>
          <button type="submit" id="submit-btn" class="btn-premium primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="confirm-modal" class="modal">
    <div class="modal-content card-premium" style="max-width: 450px; border-radius: 0; text-align: center; padding: 3.5rem !important;">
      <h2 style="font-weight: 900; margin-bottom: 0.5rem;">¿Desactivar Empleado?</h2>
      <p style="margin-bottom: 2.5rem;"><strong id="confirm-user-name"></strong> dejará de tener acceso.</p>
      <div class="form-actions">
        <button type="button" id="cancel-confirm" class="btn-premium outline">Cancelar</button>
        <button type="button" id="execute-delete" class="btn-premium primary danger" style="background: #ef4444;">Desactivar</button>
      </div>
    </div>
  </div>

  <div id="company-modal" class="modal">
    <div class="modal-content card-premium" style="max-width: 450px; border-radius: 0; text-align: center; padding: 3.5rem !important;">
      <h2 style="font-weight: 900; margin-bottom: 2rem;">Añadir Nueva Empresa</h2>
      <div class="input-container full-width" style="margin-bottom: 2rem;">
        <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
        <input type="text" id="new-company-name" placeholder="Nombre de la empresa" required />
      </div>
      <div class="form-actions">
        <button type="button" id="close-company-modal" class="btn-premium outline">Cancelar</button>
        <button type="button" id="save-company" class="btn-premium primary">Guardar</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Script unificado para modales y acciones
  const modal = document.getElementById("modal");
  const confirmModal = document.getElementById("confirm-modal");
  const userForm = document.getElementById("user-form") as HTMLFormElement;

  // Funciones Globales (para los onclick de la tabla)
  (window as any).editarUsuario = (user) => {
    (document.getElementById("user-id") as HTMLInputElement).value = user.id;
    (document.getElementById("field-name") as HTMLInputElement).value = user.full_name;
    (document.getElementById("field-id") as HTMLInputElement).value = user.employee_id;
    (document.getElementById("field-dept") as HTMLInputElement).value = user.department;
    (window as any).seleccionarEmpresa(user.company);
    document.getElementById("modal-title").textContent = "Editar Empleado";
    modal?.classList.add("active");
  };

  (window as any).confirmarDesactivar = (id, name) => {
    const nameEl = document.getElementById("confirm-user-name");
    if (nameEl) nameEl.textContent = name;
    (document.getElementById("execute-delete") as any).dataset.id = id;
    confirmModal?.classList.add("active");
  };

  (window as any).reactivarUsuario = async (id) => {
    const res = await fetch(`/api/admin/reactivate-user.php?id=${id}`, { method: "POST" });
    if (res.ok) (window as any).cargarDatos();
  };

  // Formulario Usuario
  userForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(userForm));
    const res = await fetch("/api/admin/create-user.php", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    if (res.ok) {
      modal?.classList.remove("active");
      (window as any).cargarDatos();
    }
  });

  // Ejecutar Desactivación
  document.getElementById("execute-delete")?.addEventListener("click", async () => {
    const btn = document.getElementById("execute-delete") as HTMLElement;
    const id = btn.dataset.id;
    if (!id) return;
    
    const res = await fetch(`/api/admin/deactivate-user.php?id=${id}`, { method: "POST" });
    if (res.ok) {
      confirmModal?.classList.remove("active");
      (window as any).cargarDatos();
    }
  });

  // Lógica de Empresas
  const companyModal = document.getElementById("company-modal");
  document.getElementById("open-company-modal")?.addEventListener("click", () => companyModal?.classList.add("active"));
  document.getElementById("close-company-modal")?.addEventListener("click", () => companyModal?.classList.remove("active"));
  
  document.getElementById("save-company")?.addEventListener("click", async () => {
    const nameInput = document.getElementById("new-company-name") as HTMLInputElement;
    const name = nameInput.value;
    if (!name) return;
    const res = await fetch(`/api/admin/companies.php?name=${encodeURIComponent(name)}`, { method: "POST" });
    if (res.ok) {
      nameInput.value = "";
      companyModal?.classList.remove("active");
      (window as any).cargarDatos(true);
    }
  });
</script>

<style>
  * { box-sizing: border-box; }
  .content { padding: 3rem 1rem; max-width: 1200px; margin: 0 auto; width: 100%; }
  .management-card { width: 100%; display: flex; flex-direction: column; align-items: center; max-width: 100%; }

  .gradient-text {
    background: linear-gradient(to right, #273469 0%, #4A90E2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 900;
    font-size: 3.2rem;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-bottom: 3.5rem;
    width: 100%;
  }

  .filters-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-bottom: 2.5rem;
    background: #f8fafc;
    padding: 1rem 1.5rem;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
  }

  .action-buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-main-action {
    height: 48px;
    border-radius: 12px;
    font-weight: 800;
    font-size: 1rem;
    min-width: 130px;
  }

  .left-filters {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Estilos para elementos dinámicos inyectados por JS */
  :global(.tab-btn) {
    border: none;
    background: transparent;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.85rem;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }

  :global(.tab-btn.active) {
    background: white;
    color: #4a90e2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }

  :global(.btn-action) {
    background: none;
    border: 1px solid;
    padding: 6px 12px;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    font-size: 0.8rem;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }
  
  :global(.btn-action.edit) { border-color: #dbeafe; color: #3b82f6; }
  :global(.btn-action.edit:hover) { background: #eff6ff; }
  
  :global(.btn-action.deactivate) { border-color: #fee2e2; color: #ef4444; }
  :global(.btn-action.deactivate:hover) { background: #fef2f2; }

  :global(.btn-action.reactivate) { border-color: #dcfce7; color: #22c55e; }
  :global(.btn-action.reactivate:hover) { background: #f0fdf4; }

  :global(.id-code) { 
    background: #f1f5f9; 
    padding: 4px 8px; 
    border-radius: 6px; 
    font-family: monospace; 
    color: #475569; 
  }

  :global(.user-name) { font-weight: 700; color: #1e293b; }
  
  :global(.tag-innova), :global(.tag-einsur), :global(.tag-scg) { 
    padding: 4px 10px; 
    border-radius: 99px; 
    font-weight: 700; 
    font-size: 0.75rem; 
  }
  :global(.tag-innova) { color: #4A90E2; background: #eff6ff; }
  :global(.tag-einsur) { color: #273469; background: #f1f5f9; }
  :global(.tag-scg) { color: #64748b; background: #f8fafc; }

  .company-tabs {

    display: flex;
    background: #e2e8f0;
    padding: 4px;
    border-radius: 10px;
    gap: 2px;
  }

  .tab-btn {
    border: none;
    background: transparent;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.85rem;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-btn.active {
    background: white;
    color: #4a90e2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }

