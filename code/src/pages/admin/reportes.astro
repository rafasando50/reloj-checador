---
import Layout from "../../layouts/Layout.astro";

// Protección: Solo admins
const adminSession = Astro.cookies.get("admin_session");
if (!adminSession) {
  return Astro.redirect("/admin/login");
}
---

<Layout title="Reportes Globales">
  <main class="contenedor-principal">
    <div class="card-premium reports-card">
      <h1
        style="background: linear-gradient(to right, #273469 0%, #4A90E2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 900; font-size: 3.2rem; text-align: center; font-family: 'Inter', sans-serif; margin-bottom: 3.5rem; width: 100%;"
      >
        Registros
      </h1>

      <div class="filtros-seccion">
        <div class="form-grid">
          <div class="input-group">
            <label>Desde:</label>
            <input type="date" id="fecha-inicio" class="input-premium" />
          </div>
          <div class="input-group">
            <label>Hasta:</label>
            <input type="date" id="fecha-fin" class="input-premium" />
          </div>
          <div class="input-group">
            <label>Empresa:</label>
            <div class="custom-select-wrapper">
              <input type="hidden" id="filtro-empresa" value="" />
              <div class="custom-select-trigger" id="company-trigger">
                <span id="selected-company-label">Todas</span>
                <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
              <div class="custom-options" id="company-options">
                <div class="option selected" data-value="">Todas</div>
                <div class="option" data-value="Einsur">Einsur</div>
                <div class="option" data-value="Innova">Innova</div>
              </div>
            </div>
          </div>
          <div class="input-group">
            <label>Empleado ID:</label>
            <input
              type="text"
              id="empleado-id"
              placeholder="Todos"
              class="input-premium"
            />
          </div>
        </div>

        <div class="botones-filtros">
          <button
            id="btn-buscar"
            class="btn-premium primary"
            style="min-width: 180px; height: 52px; border-radius: 12px; font-weight: 800; font-size: 1rem; background: #4A90E2; color: white; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 14px 0 rgba(74, 144, 226, 0.35);"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="11" cy="11" r="8"></circle><line
                x1="21"
                y1="21"
                x2="16.65"
                y2="16.65"></line>
            </svg>
            Buscar
          </button>
          <button
            id="btn-exportar"
            class="btn-premium outline"
            style="min-width: 180px; height: 52px; border-radius: 12px; font-weight: 800; font-size: 1rem; background: white; color: #64748b; border: 2px solid #e2e8f0; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
              ></path><polyline points="14 2 14 8 20 8"></polyline><line
                x1="16"
                y1="13"
                x2="8"
                y2="13"></line><line x1="16" y1="17" x2="8" y2="17"
              ></line><polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            Exportar
          </button>
        </div>
      </div>

      <div class="tabla-container">
        <table>
          <thead>
            <tr>
              <th>Empleado</th>
              <th>Entrada</th>
              <th>Salida</th>
              <th>Estado</th>
              <th>Puntualidad</th>
            </tr>
          </thead>
          <tbody id="tabla-cuerpo">
            <tr>
              <td colspan="5" class="sin-registros">
                Usa los filtros para buscar registros.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Lógica para el Custom Dropdown
  const trigger = document.getElementById('company-trigger');
  const options = document.getElementById('company-options');
  const hiddenInput = document.getElementById('filtro-empresa') as HTMLInputElement;

  trigger?.addEventListener('click', () => {
    options?.classList.toggle('active');
    trigger?.classList.toggle('active');
  });

  document.querySelectorAll('.option').forEach(opt => {
    opt.addEventListener('click', () => {
      const val = (opt as HTMLElement).dataset.value || '';
      const label = (opt as HTMLElement).innerText;
      
      if (hiddenInput) hiddenInput.value = val;
      const labelEl = document.getElementById('selected-company-label');
      if (labelEl) labelEl.innerText = label;
      
      document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      
      options?.classList.remove('active');
      trigger?.classList.remove('active');
      
      // Auto-buscar al cambiar empresa (opcional, igual que en empleados)
      document.getElementById("btn-buscar")?.click();
    });
  });

  window.addEventListener('click', (e) => {
    if (!trigger?.contains(e.target as Node) && !options?.contains(e.target as Node)) {
      options?.classList.remove('active');
      trigger?.classList.remove('active');
    }
  });

  // Script de búsqueda y exportación
  document.addEventListener("DOMContentLoaded", () => {
    const now = new Date();
    const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);

    const formatDate = (date: Date) => {
      const d = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
      return d.toISOString().split("T")[0];
    };

    const inputInicio = document.getElementById("fecha-inicio") as HTMLInputElement;
    const inputFin = document.getElementById("fecha-fin") as HTMLInputElement;

    if (inputInicio && !inputInicio.value) inputInicio.value = formatDate(firstDay);
    if (inputFin && !inputFin.value) inputFin.value = formatDate(now);

    document.getElementById("btn-buscar")?.click();
  });

  document.getElementById("btn-buscar")?.addEventListener("click", async () => {
    const inicio = (document.getElementById("fecha-inicio") as HTMLInputElement).value;
    const fin = (document.getElementById("fecha-fin") as HTMLInputElement).value;
    const empId = (document.getElementById("empleado-id") as HTMLInputElement).value;
    const empresa = (document.getElementById("filtro-empresa") as HTMLInputElement).value;

    const res = await fetch(
      `/api/reports?start=${inicio}&end=${fin}&employee_id=${empId}&company=${empresa}`,
    );
    const data = (await res.json()) as any[];

    const cuerpo = document.getElementById("tabla-cuerpo");
    if (cuerpo) {
      if (data.length === 0) {
        cuerpo.innerHTML =
          '<tr><td colspan="5" class="sin-registros">No se encontraron registros.</td></tr>';
      } else {
        cuerpo.innerHTML = data
          .map(
            (r) => `
          <tr>
            <td class="nombre">${r.full_name}</td>
            <td>${r.entrada ? new Date(r.entrada).toLocaleString() : "-"}</td>
            <td>${r.salida ? new Date(r.salida).toLocaleString() : "-"}</td>
            <td>
              <span class="badge-status ${r.salida ? 'completado' : 'pendiente'}">
                ${r.salida ? "Completado" : "En Turno"}
              </span>
            </td>
            <td>
              <span class="badge-puntualidad ${r.puntualidad.toLowerCase().replace(' ', '-')}">
                ${r.puntualidad}
              </span>
            </td>
          </tr>
        `,
          )
          .join("");
      }
    }
  });

  document.getElementById("btn-exportar")?.addEventListener("click", () => {
    const inicio = (document.getElementById("fecha-inicio") as HTMLInputElement).value;
    const fin = (document.getElementById("fecha-fin") as HTMLInputElement).value;
    const empId = (document.getElementById("empleado-id") as HTMLInputElement).value;
    const empresa = (document.getElementById("filtro-empresa") as HTMLInputElement).value;
    window.location.href = `/api/reports/export?start=${inicio}&end=${fin}&employee_id=${empId}&company=${empresa}`;
  });
</script>

<style>
  .contenedor-principal {
    padding: 3rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .reports-card {
    width: 100%;
    max-width: 1100px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.5rem !important;
  }

  .filtros-seccion {
    width: 100%;
    margin-bottom: 3.5rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .input-group label {
    font-size: 0.85rem;
    font-weight: 800;
    color: #273469;
    text-align: center;
    width: 100%;
  }
  .input-premium {
    width: 100%;
    padding: 12px 14px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.95rem;
    color: #1e293b;
    background: #f8fafc;
    transition: all 0.2s;
    box-sizing: border-box;
  }
  .input-premium:focus {
    border-color: #4a90e2;
    background: white;
    outline: none;
    box-shadow: 0 0 0 4px rgba(74, 144, 226, 0.1);
  }

  /* Custom Select Styles (from empleados.astro) */
  .custom-select-wrapper { position: relative; width: 100%; }
  .custom-select-trigger { 
    width: 100%;
    padding: 12px 16px; 
    border: 2px solid #e2e8f0; 
    border-radius: 12px;
    background: #f8fafc; 
    cursor: pointer; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    font-weight: 500; 
    font-size: 0.95rem;
    color: #1e293b;
    box-sizing: border-box;
  }
  .custom-select-trigger.active { border-color: #4a90e2; background: white; }
  .custom-select-trigger.active .arrow { transform: rotate(180deg); }
  .custom-select-trigger .arrow { transition: transform 0.3s; color: #94a3b8; }
  
  .custom-options { 
    position: absolute; top: calc(100% + 5px); left: 0; right: 0; background: white; 
    border: 2px solid #e2e8f0; border-radius: 12px; z-index: 100; display: none; 
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  .custom-options.active { display: block; }
  .option { padding: 12px 16px; cursor: pointer; font-size: 0.95rem; color: #475569; text-align: left; }
  .option:hover { background: #f1f5f9; color: #4a90e2; }
  .option.selected { background: #eff6ff; color: #4a90e2; font-weight: 700; }

  .botones-filtros {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .tabla-container {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    overflow: hidden;
    background: #f8fafc;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }
  th {
    background: #f1f5f9;
    padding: 1.25rem;
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #475569;
    font-weight: 800;
    border-bottom: 1px solid #e2e8f0;
  }
  td {
    padding: 2rem 1.25rem;
    border-top: 1px solid #e2e8f0;
    text-align: center;
    font-size: 1rem;
    line-height: 1.5;
  }
  tr {
    height: 100px;
  }

  .nombre {
    font-weight: 700;
    color: #1e293b;
  }
  :global(.sin-registros) {
    text-align: center;
    color: #94a3b8;
    padding: 6rem 1rem !important;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 500;
  }

  /* Badges */
  :global(.badge-status), :global(.badge-puntualidad) {
    font-size: 0.65rem;
    font-weight: 900;
    padding: 6px 12px;
    border-radius: 6px;
    text-transform: uppercase;
    display: inline-block;
    letter-spacing: 0.02em;
  }
  :global(.badge-status.completado) { background: #e1fdec !important; color: #065f46 !important; border: 1px solid #34d399; }
  :global(.badge-status.pendiente) { background: #fff9db !important; color: #92400e !important; border: 1px solid #fbbf24; }
  :global(.badge-puntualidad.a-tiempo) { background: #ecfdf5 !important; color: #059669 !important; border: 1px solid #6ee7b7; }
  :global(.badge-puntualidad.retardo) { background: #fffbeb !important; color: #d97706 !important; border: 1px solid #fcd34d; }
  :global(.badge-puntualidad.falta) { background: #fef2f2 !important; color: #dc2626 !important; border: 1px solid #fca5a5; }

  .btn-premium {
    padding: 12px 24px;
    border: none;
    cursor: pointer;
    font-weight: 800;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.2s;
  }
  .btn-premium.primary { background: #4a90e2; color: white; }
  .btn-premium.outline { background: white; color: #64748b; border: 2px solid #e2e8f0; }
</style>
