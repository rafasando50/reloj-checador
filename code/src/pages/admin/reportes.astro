---
import Layout from "../../layouts/Layout.astro";
---

<script is:inline src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>

<script>
  // Verificar sesión admin
  if (!document.cookie.split(';').some((item) => item.trim().startsWith('admin_session='))) {
    window.location.replace("/admin/login");
  }

  // Cargar empresas dinámicamente
  async function cargarEmpresas() {
    try {
      const res = await fetch("/api/companies.php");
      const companies = await res.json();
      const optionsContainer = document.getElementById("company-options");
      if (optionsContainer) {
        optionsContainer.innerHTML = '<div class="option selected" data-value="">Todas</div>';
        companies.forEach(c => {
          const div = document.createElement("div");
          div.className = "option";
          div.dataset.value = c.name;
          div.textContent = c.name;
          div.onclick = () => seleccionarEmpresa(c.name);
          optionsContainer.appendChild(div);
        });
      }
    } catch (e) {
      console.error("Error al cargar empresas:", e);
    }
  }

  function seleccionarEmpresa(name) {
    const hiddenInput = document.getElementById('filtro-empresa') as HTMLInputElement;
    if (hiddenInput) hiddenInput.value = name;
    const labelEl = document.getElementById('selected-company-label');
    if (labelEl) labelEl.innerText = name || "Todas";
    document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
    document.querySelector(`.option[data-value="${name}"]`)?.classList.add('selected');
    document.getElementById('company-options')?.classList.remove('active');
    document.getElementById('company-trigger')?.classList.remove('active');
    // @ts-ignore
    document.getElementById("btn-buscar")?.click();
  }

  document.addEventListener("DOMContentLoaded", () => {
    cargarEmpresas();
  });
</script>

<Layout title="Reportes Globales">
  <main class="contenedor-principal">
    <div class="card-premium reports-card">
      <h1 class="titulo-principal">
        Reportes
      </h1>

      <div class="filtros-seccion">
        <div class="form-grid">
          <div class="input-group">
            <label>Desde:</label>
            <input type="date" id="fecha-inicio" class="input-premium" />
          </div>
          <div class="input-group">
            <label>Hasta:</label>
            <input type="date" id="fecha-fin" class="input-premium" />
          </div>
          <div class="input-group">
            <label>Empresa:</label>
            <div class="custom-select-wrapper">
              <input type="hidden" id="filtro-empresa" value="" />
              <div class="custom-select-trigger" id="company-trigger">
                <span id="selected-company-label">Todas</span>
                <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
              <div class="custom-options" id="company-options">
                <div class="option selected" data-value="">Todas</div>
                {/* Cargado dinámicamente */}
              </div>
            </div>
          </div>
          <div class="input-group">
            <label>Empleado ID:</label>
            <input
              type="text"
              id="empleado-id"
              placeholder="Todos"
              class="input-premium"
            />
          </div>
        </div>

        <div class="botones-filtros">
          <button
            id="btn-buscar"
            class="btn-premium primary btn-action"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="11" cy="11" r="8"></circle><line
                x1="21"
                y1="21"
                x2="16.65"
                y2="16.65"></line>
            </svg>
            Buscar
          </button>
          <button
            id="btn-exportar"
            class="btn-premium outline btn-action"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
              ></path><polyline points="14 2 14 8 20 8"></polyline><line
                x1="16"
                y1="13"
                x2="8"
                y2="13"></line><line x1="16" y1="17" x2="8" y2="17"
              ></line><polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            Exportar
          </button>
        </div>
      </div>

      <div class="tabla-container">
        <table>
          <thead>
            <tr>
              <th>Empleado</th>
              <th>Entrada</th>
              <th>Salida</th>
              <th>Ubicación E.</th>
              <th>Ubicación S.</th>
              <th>Estado</th>
              <th>Puntualidad</th>
            </tr>
          </thead>
          <tbody id="tabla-cuerpo">
            <tr>
              <td colspan="5" class="sin-registros">
                Usa los filtros para buscar registros.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Lógica para el Custom Dropdown
  const trigger = document.getElementById('company-trigger');
  const options = document.getElementById('company-options');
  const hiddenInput = document.getElementById('filtro-empresa') as HTMLInputElement;

  trigger?.addEventListener('click', () => {
    options?.classList.toggle('active');
    trigger?.classList.toggle('active');
  });

  document.querySelectorAll('.option').forEach(opt => {
    opt.addEventListener('click', () => {
      const val = (opt as HTMLElement).dataset.value || '';
      const label = (opt as HTMLElement).innerText;
      
      if (hiddenInput) hiddenInput.value = val;
      const labelEl = document.getElementById('selected-company-label');
      if (labelEl) labelEl.innerText = label;
      
      document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      
      options?.classList.remove('active');
      trigger?.classList.remove('active');
      
      // Auto-buscar al cambiar empresa (opcional, igual que en empleados)
      document.getElementById("btn-buscar")?.click();
    });
  });

  window.addEventListener('click', (e) => {
    if (!trigger?.contains(e.target as Node) && !options?.contains(e.target as Node)) {
      options?.classList.remove('active');
      trigger?.classList.remove('active');
    }
  });

  // Script de búsqueda y exportación
  document.addEventListener("DOMContentLoaded", () => {
    const now = new Date();
    const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);

    const formatDate = (date: Date) => {
      const d = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
      return d.toISOString().split("T")[0];
    };

    const inputInicio = document.getElementById("fecha-inicio") as HTMLInputElement;
    const inputFin = document.getElementById("fecha-fin") as HTMLInputElement;

    if (inputInicio && !inputInicio.value) inputInicio.value = formatDate(firstDay);
    if (inputFin && !inputFin.value) inputFin.value = formatDate(now);

    document.getElementById("btn-buscar")?.click();
  });

  document.getElementById("btn-buscar")?.addEventListener("click", async () => {
    const inicio = (document.getElementById("fecha-inicio") as HTMLInputElement).value;
    const fin = (document.getElementById("fecha-fin") as HTMLInputElement).value;
    const empId = (document.getElementById("empleado-id") as HTMLInputElement).value;
    const empresa = (document.getElementById("filtro-empresa") as HTMLInputElement).value;

    const res = await fetch(
      `/api/reports.php?start=${inicio}&end=${fin}&employee_id=${empId}&company=${empresa}`,
    );
    const data = (await res.json()) as any[];

    const cuerpo = document.getElementById("tabla-cuerpo");
    if (cuerpo) {
      if (data.length === 0) {
        cuerpo.innerHTML =
          '<tr><td colspan="5" class="sin-registros">No se encontraron registros.</td></tr>';
      } else {
        cuerpo.innerHTML = data
          .map(
            (r) => `
          <tr>
            <td class="nombre">${r.full_name}</td>
            <td>${r.entrada ? new Date(r.entrada).toLocaleString() : "-"}</td>
            <td>${r.salida ? new Date(r.salida).toLocaleString() : "-"}</td>
            <td style="font-size: 0.8rem; color: #64748b;">${r.entrada_estacion || "-"}</td>
            <td style="font-size: 0.8rem; color: #64748b;">${r.salida ? (r.salida_estacion || "-") : "-"}</td>
            <td>
              <span class="badge-status ${r.salida ? 'completado' : 'pendiente'}">
                ${r.salida ? "Completado" : "En Turno"}
              </span>
            </td>
            <td>
              <span class="badge-puntualidad ${r.puntualidad.toLowerCase().replace(' ', '-')}">
                ${r.puntualidad}
              </span>
            </td>
          </tr>
        `,
          )
          .join("");
      }
    }
  });

  document.getElementById("btn-exportar")?.addEventListener("click", async () => {
    const inicio = (document.getElementById("fecha-inicio") as HTMLInputElement).value;
    const fin = (document.getElementById("fecha-fin") as HTMLInputElement).value;
    const empId = (document.getElementById("empleado-id") as HTMLInputElement).value;
    const empresa = (document.getElementById("filtro-empresa") as HTMLInputElement).value;

    // Obtener datos actuales para exportar
    const res = await fetch(
      `/api/reports.php?start=${inicio}&end=${fin}&employee_id=${empId}&company=${empresa}`,
    );
    const data = await res.json();

    if (!data || data.length === 0) {
      alert("No hay datos para exportar");
      return;
    }

    // Formatear datos para Excel
    const excelData = data.map(r => ({
      'Empleado': r.full_name,
      'ID': r.employee_id,
      'Entrada': r.entrada ? new Date(r.entrada).toLocaleString() : "-",
      'Salida': r.salida ? new Date(r.salida).toLocaleString() : "En Turno",
      'Ubicación Entrada': r.entrada_estacion || "Remoto",
      'Ubicación Salida': r.salida ? (r.salida_estacion || "Remoto") : "-",
      'Puntualidad': r.puntualidad
    }));

    // Crear libro y hoja
    // @ts-ignore
    const ws = XLSX.utils.json_to_sheet(excelData);
    // @ts-ignore
    const wb = XLSX.utils.book_new();
    // @ts-ignore
    XLSX.utils.book_append_sheet(wb, ws, "Reporte");

    // Descargar
    // @ts-ignore
    XLSX.writeFile(wb, `Reporte_Asistencia_${inicio}_al_${fin}.xlsx`);
  });
</script>

<style>
  .contenedor-principal {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .reports-card {
    width: 100%;
    max-width: 1100px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.5rem !important;
    position: relative;
  }

  .titulo-principal {
    background: linear-gradient(to right, #273469 0%, #4A90E2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 900;
    font-size: 3.2rem;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-bottom: 3.5rem;
    width: 100%;
  }

  .filtros-seccion {
    width: 100%;
    margin-bottom: 3.5rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .input-group label {
    font-size: 0.85rem;
    font-weight: 800;
    color: #273469;
    text-align: left;
    width: 100%;
  }
  .input-premium {
    width: 100%;
    padding: 12px 14px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.95rem;
    color: #1e293b;
    background: #f8fafc;
    transition: all 0.2s;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
  }
  .input-premium:focus {
    border-color: #4a90e2;
    background: white;
    outline: none;
    box-shadow: 0 0 0 4px rgba(74, 144, 226, 0.1);
  }

  /* Custom Select Styles */
  :global(.custom-select-wrapper) { position: relative; width: 100%; }
  :global(.custom-select-trigger) { 
    width: 100%;
    padding: 12px 16px; 
    border: 2px solid #e2e8f0; 
    border-radius: 12px;
    background: #f8fafc; 
    cursor: pointer; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    font-weight: 500; 
    font-size: 0.95rem;
    color: #1e293b;
    box-sizing: border-box;
  }
  :global(.custom-select-trigger.active) { border-color: #4a90e2; background: white; }
  :global(.custom-select-trigger.active .arrow) { transform: rotate(180deg); }
  :global(.custom-select-trigger .arrow) { transition: transform 0.3s; color: #94a3b8; }
  
  :global(.custom-options) { 
    position: absolute; top: calc(100% + 5px); left: 0; right: 0; background: white; 
    border: 2px solid #e2e8f0; border-radius: 12px; z-index: 100; display: none; 
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  :global(.custom-options.active) { display: block; }
  :global(.option) { padding: 12px 16px; cursor: pointer; font-size: 0.95rem; color: #475569; text-align: left; }
  :global(.option:hover) { background: #f1f5f9; color: #4a90e2; }
  :global(.option.selected) { background: #eff6ff; color: #4a90e2; font-weight: 700; }

  .botones-filtros {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .btn-action {
    min-width: 180px;
    height: 52px;
  }

  .tabla-container {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    overflow-x: auto;
    background: #f8fafc;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }
  th {
    background: #f1f5f9;
    padding: 1.25rem;
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #475569;
    font-weight: 800;
    border-bottom: 1px solid #e2e8f0;
  }
  td {
    padding: 1.5rem 1.25rem;
    border-top: 1px solid #e2e8f0;
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  tr:hover {
    background: #f1f5f9;
  }

  .nombre {
    font-weight: 700;
    color: #1e293b;
  }
  :global(.sin-registros) {
    text-align: center;
    color: #94a3b8;
    padding: 6rem 1rem !important;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 500;
  }

  /* Badges */
  :global(.badge-status), :global(.badge-puntualidad) {
    font-size: 0.65rem;
    font-weight: 900;
    padding: 6px 12px;
    border-radius: 6px;
    text-transform: uppercase;
    display: inline-block;
    letter-spacing: 0.02em;
  }
  :global(.badge-status.completado) { background: #e1fdec !important; color: #065f46 !important; border: 1px solid #34d399; }
  :global(.badge-status.pendiente) { background: #fff9db !important; color: #92400e !important; border: 1px solid #fbbf24; }
  :global(.badge-puntualidad.a-tiempo) { background: #ecfdf5 !important; color: #059669 !important; border: 1px solid #6ee7b7; }
  :global(.badge-puntualidad.retardo) { background: #fffbeb !important; color: #d97706 !important; border: 1px solid #fcd34d; }
  :global(.badge-puntualidad.falta) { background: #fef2f2 !important; color: #dc2626 !important; border: 1px solid #fca5a5; }

  .btn-premium {
    padding: 12px 24px;
    border: none;
    cursor: pointer;
    font-weight: 800;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .btn-premium.primary { background: #4a90e2; color: white; box-shadow: 0 4px 14px 0 rgba(74, 144, 226, 0.35); }
  .btn-premium.outline { background: white; color: #64748b; border: 2px solid #e2e8f0; }

  /* Responsive Design */
  @media (max-width: 768px) {
    .contenedor-principal { padding: 2rem 1.25rem; }
    .reports-card { padding: 2rem !important; }
    .titulo-principal { font-size: 2.5rem; margin-bottom: 2.5rem; }
    .form-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 425px) {
    .contenedor-principal { padding: 1rem 0.5rem; }
    .reports-card { 
      padding: 1.5rem !important; 
      border-radius: 16px;
      margin-top: -1.5rem;
    }
    .titulo-principal { font-size: 2rem; margin-bottom: 1.5rem; text-align: left; }
    .form-grid { grid-template-columns: 1fr; gap: 0.8rem; margin-bottom: 1.5rem; }
    .botones-filtros { flex-direction: column; gap: 0.8rem; width: 100%; }
    .btn-action { width: 100%; min-width: 0; }
    .tabla-container { border-radius: 12px; }
    td { font-size: 0.85rem; padding: 1rem 0.75rem; }
    th { padding: 1rem 0.75rem; }
  }

  @media (max-width: 375px) {
    .reports-card { padding: 1.25rem !important; margin-top: -2rem; }
    .titulo-principal { font-size: 1.8rem; }
  }

  @media (max-width: 320px) {
    .contenedor-principal { padding: 0.5rem 0.25rem; }
    .reports-card { padding: 1rem !important; margin-top: -2.5rem; }
    .titulo-principal { font-size: 1.6rem; margin-bottom: 1rem; }
    .btn-premium { height: 46px; font-size: 0.9rem; }
  }
</style>
