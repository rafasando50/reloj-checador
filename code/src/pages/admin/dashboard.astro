---
import Layout from "../../layouts/Layout.astro";

const modules = [
  {
    title: "Escáner",
    description: "Registrar entradas y salidas en tiempo real",
    icon: "camera",
    link: "/admin/scanner",
    color: "#4A90E2",
  },
  {
    title: "Hoy",
    description: "Ver quién está trabajando en este momento",
    icon: "calendar",
    link: "/admin/hoy",
    color: "#4A90E2",
  },
  {
    title: "Reportes",
    description: "Historial completo y exportación a Excel",
    icon: "file-text",
    link: "/admin/reportes",
    color: "#4A90E2",
  },
  {
    title: "Personal",
    description: "Administrar empleados, altas y bajas",
    icon: "users",
    link: "/admin/empleados",
    color: "#4A90E2",
  },
];
---

<script>
  // Verificar sesión admin en el cliente
  if (!document.cookie.split(';').some((item) => item.trim().startsWith('admin_session='))) {
    window.location.replace("/admin/login");
  }

  async function cargarDashboard() {
    if (window.innerWidth < 1024) return;
    
    try {
      const res = await fetch("/api/daily.php?mode=dashboard");
      const data = await res.json();
      
      const elEntradas = document.getElementById('stat-entradas');
      const elRetardos = document.getElementById('stat-retardos');
      if (elEntradas) elEntradas.textContent = data.today_count.toString();
      if (elRetardos) elRetardos.textContent = data.week_delays.toString();
      
      const list = document.getElementById('recent-list');
      if (list) {
        if (!data.recent || data.recent.length === 0) {
          list.innerHTML = '<div class="empty-state">No hay actividad hoy</div>';
        } else {
          list.innerHTML = data.recent.map((r: any) => {
            const statusClass = (r.puntualidad || 'a-tiempo').toLowerCase().replace(/\s+/g, '-');
            return `
              <div class="recent-item-new">
                <div class="status-circle ${statusClass}"></div>
                <div class="recent-info-new">
                  <span class="recent-name-new">${r.full_name}</span>
                  <span class="recent-time-new">${new Date(r.entrada).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                </div>
              </div>
            `;
          }).join('');
        }
      }
    } catch (e) {
      console.error("Error cargando dashboard stats:", e);
    }
  }

  document.addEventListener("DOMContentLoaded", cargarDashboard);
</script>


<Layout title="Panel de Control">
  <div class="dashboard-bg-decor">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <main class="dashboard-container">
    <div class="welcome-header">
      <h1 class="gradient-text">Panel de Control</h1>
    </div>

    <!-- Stats Row (Desktop Only) -->
    <div class="stats-row">
      <div class="stat-card card-premium">
        <div class="stat-icon" style="background: #4A90E2; color: white;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-entradas">0</span>
          <span class="stat-label">Entradas Hoy</span>
        </div>
      </div>
      <a href="/admin/reportes?filtro=retardos" class="stat-card card-premium" style="text-decoration: none;">
        <div class="stat-icon" style="background: #F59E0B; color: white;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-retardos">0</span>
          <span class="stat-label">Retardos (Semana)</span>
        </div>
      </a>
    </div>

    <div class="modules-grid">
      {
        modules.map((module) => (
          <a href={module.link} class="module-card card-premium">
            <div
              class="icon-box"
              style={`background: ${module.color}15; color: ${module.color};`}
            >
              {module.icon === "camera" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                  <circle cx="12" cy="13" r="4" />
                </svg>
              )}
              {module.icon === "calendar" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
              )}
              {module.icon === "file-text" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <polyline points="10 9 9 9 8 9" />
                </svg>
              )}
              {module.icon === "users" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              )}
            </div>
            <div class="module-info">
              <h2>{module.title}</h2>
              <p>{module.description}</p>
            </div>
            <div class="arrow-indicator">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Recent Activity (Desktop Only) -->
    <aside class="recent-activity-aside card-premium">
      <div class="section-header">
        <h3>Actividad Reciente</h3>
        <a href="/admin/hoy" class="view-all">Ver todos</a>
      </div>
      <div id="recent-list" class="recent-list">
        <div class="loading-state">Cargando actividad...</div>
      </div>
    </aside>
  </main>
</Layout>

<style>
  .dashboard-container {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  /* Dashboard styles */

  /* Dashboard styles */
  .stats-row, .recent-activity-aside { display: none; }

  @media (min-width: 1024px) {
    .dashboard-container {
      max-width: 100%;
      display: grid;
      grid-template-columns: 1fr 420px;
      grid-template-rows: auto auto 1fr;
      gap: 2rem;
      min-height: calc(100vh - 64px);
      padding: 3rem 8%;
      background: var(--bg-primary) !important;
      transition: background-color 0.3s ease;
    }

    .welcome-header { grid-column: 1 / span 2; margin-bottom: 1rem; }
    
    .stats-row { 
      grid-column: 1 / span 2; 
      display: grid; 
      grid-template-columns: 1fr 1fr; 
      gap: 1.5rem; 
      margin-bottom: 1rem; 
    }

    .modules-grid { grid-column: 1; grid-row: 3; }

    .recent-activity-aside { 
      display: block; 
      grid-column: 2; 
      grid-row: 3; 
      padding: 1.5rem !important;
      border-radius: 24px;
      height: 100%;
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-md);
    }

    .gradient-text {
      -webkit-text-fill-color: transparent !important;
      background: linear-gradient(
        to right,
        #4a90e2 0%,
        #273469 100%
      ) !important;
      background-size: 200% auto !important;
      -webkit-background-clip: text !important;
      background-clip: text !important;
      animation: shine 4s linear infinite !important;
    }
    .module-card {
      background: var(--bg-secondary) !important;
      box-shadow: var(--shadow-md) !important;
    }
  }

  /* Stat Cards */
  .stat-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem !important;
    border-radius: 24px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-sm);
    border-top: 2px solid #4a90e2;
  }
  a.stat-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  a.stat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.1);
  }
  .stat-card:last-child {
    border-top-color: #f59e0b;
  }
  .stat-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-main);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* Recent Activity Refined */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .section-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-main);
  }
  .view-all {
    font-size: 0.8rem;
    color: #4a90e2;
    text-decoration: none;
    font-weight: 700;
  }

  :global(.recent-list) {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  :global(.recent-item-new) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
  }
  :global(.status-circle) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }
  :global(.status-circle.a-tiempo) { background: #34d399 !important; box-shadow: 0 0 8px rgba(52, 211, 153, 0.4); }
  :global(.status-circle.retardo) { background: #fbbf24 !important; box-shadow: 0 0 8px rgba(251, 191, 36, 0.4); }
  :global(.status-circle.falta) { background: #f87171 !important; box-shadow: 0 0 8px rgba(248, 113, 113, 0.4); }

  :global(.recent-info-new) {
    flex: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  :global(.recent-name-new) {
    font-size: 0.95rem;
    color: var(--text-main);
    font-weight: 500;
  }
  :global(.recent-time-new) {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .loading-state, .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: #94a3b8;
    font-size: 0.95rem;
    font-weight: 500;
  }

  /* Background Decoration */
  .dashboard-bg-decor {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .blob {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
  }
  .blob-1 {
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, #4a90e2, transparent);
  }
  .blob-2 {
    bottom: -200px;
    left: -100px;
    background: radial-gradient(circle, #f59e0b, transparent);
  }

  @keyframes shine {
    to {
      background-position: 200% center;
    }
  }

  .welcome-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .gradient-text {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    background: linear-gradient(to right, #273469 0%, #4a90e2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .module-card {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    border: 1px solid #e2e8f0;
    border-radius: 24px;
    background: white;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
  }

  .module-card:hover {
    transform: translateY(-8px);
    border-color: #e2e8f0;
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.1);
  }

  .icon-box {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .module-info h2 {
    margin: 0 0 4px 0;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--text-main);
  }

  .module-info p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.4;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .arrow-indicator {
    position: absolute;
    right: 2rem;
    color: #cbd5e1;
    transition: all 0.3s;
    opacity: 0;
    transform: translateX(-10px);
  }

  .module-card:hover .arrow-indicator {
    opacity: 1;
    transform: translateX(0);
    color: #4a90e2;
  }

  @media (max-width: 768px) {
    .modules-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .gradient-text {
      font-size: 2.8rem;
    }
  }

  @media (max-width: 425px) {
    .dashboard-container {
      padding: 1rem !important;
    }
    .welcome-header {
      margin-bottom: 1.5rem;
      text-align: center;
    }
    .gradient-text {
      font-size: 2.2rem;
    }
    .module-card {
      padding: 1.25rem !important;
      gap: 1rem;
      border-radius: 20px;
    }
    .icon-box {
      width: 50px;
      height: 50px;
      border-radius: 14px;
    }
    .icon-box svg {
      width: 24px;
      height: 24px;
    }
    .module-info h2 {
      font-size: 1.2rem;
    }
    .module-info p {
      font-size: 0.85rem;
    }
    .arrow-indicator {
      display: none;
    }
  }

  @media (max-width: 320px) {
    .gradient-text {
      font-size: 1.8rem;
    }
    .module-card {
      padding: 1rem !important;
    }
    .icon-box {
      width: 45px;
      height: 45px;
    }
    .module-info h2 {
      font-size: 1.1rem;
    }
  }
</style>
