---
import Layout from "../../layouts/Layout.astro";
---


<Layout title="Asistencia Diaria">
  <main class="contenedor-principal">
    <div class="card-premium daily-card">
      <h1 class="titulo-principal">
        Asistencia Diaria
      </h1>

      <div class="filtros-seccion">
        <div class="filtros-grid">
          <div class="input-group">
            <label>Empresa:</label>
            <div class="custom-select-wrapper">
              <input type="hidden" id="filtro-empresa" value="" />
              <div class="custom-select-trigger" id="company-trigger">
                <span id="selected-company-label">Todas</span>
                <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
              <div class="custom-options" id="company-options">
                <div class="option selected" data-value="">Todas</div>
                {/* Las empresas se cargarán dinámicamente vía script */}
              </div>
            </div>
          </div>
          <div class="input-group" style="width: 220px;">
            <label>Empleado:</label>
            <input
              type="text"
              id="empleado-search"
              placeholder="Nombre o ID"
              class="input-premium"
            />
          </div>
          <div class="input-group button-group" style="flex-direction: row; gap: 0.8rem; align-items: flex-end; width: 340px;">
            <button id="btn-buscar" class="btn-premium primary" style="flex: 0.8; height: 40px; font-size: 0.9rem;">
               Buscar
            </button>
            <button id="btn-limpiar" class="btn-premium outline" style="flex: 1.5; height: 40px; font-size: 0.9rem;">
               Limpiar Filtros
            </button>
          </div>
        </div>
      </div>

      <div class="tabla-container">
        <table>
          <thead>
            <tr>
              <th>Empleado</th>
              <th>Entrada</th>
              <th>Salida</th>
              <th>Ubicación E.</th>
              <th>Ubicación S.</th>
              <th>Estado</th>
              <th>Puntualidad</th>
            </tr>
          </thead>
          <tbody id="tabla-cuerpo">
            <tr>
              <td colspan="7" class="sin-registros">Cargando registros...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="acciones-footer">
        <button
          onclick="window.location.reload()"
          class="btn-premium outline"
          style="min-width: 200px; height: 52px;"
        >
          Actualizar Todo
        </button>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Verificar sesión admin
  if (!document.cookie.split(';').some((item) => item.trim().startsWith('admin_session='))) {
    window.location.replace("/admin/login");
  }

  // Cargar empresas dinámicamente
  async function cargarEmpresas() {
    try {
      const res = await fetch("/api/companies.php");
      const companies = await res.json();
      const optionsContainer = document.getElementById("company-options");
      if (optionsContainer) {
        // Mantener la opción "Todas"
        optionsContainer.innerHTML = '<div class="option selected" data-value="">Todas</div>';
        companies.forEach(c => {
          const div = document.createElement("div");
          div.className = "option";
          div.dataset.value = c.name;
          div.textContent = c.name;
          div.onclick = () => seleccionarEmpresa(c.name);
          optionsContainer.appendChild(div);
        });
      }
    } catch (e) {
      console.error("Error al cargar empresas:", e);
    }
  }

  function seleccionarEmpresa(name) {
    const hiddenInput = document.getElementById('filtro-empresa') as HTMLInputElement;
    if (hiddenInput) hiddenInput.value = name;
    const labelEl = document.getElementById('selected-company-label');
    if (labelEl) labelEl.innerText = name || "Todas";
    document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
    // Encontrar la opción y marcarla
    document.querySelector(`.option[data-value="${name}"]`)?.classList.add('selected');
    document.getElementById('company-options')?.classList.remove('active');
    document.getElementById('company-trigger')?.classList.remove('active');
    // @ts-ignore
    cargarHoy();
  }

  document.addEventListener("DOMContentLoaded", () => {
    cargarEmpresas();
  });

  // Custom Select Logic
  const trigger = document.getElementById('company-trigger');
  const options = document.getElementById('company-options');
  const hiddenInput = document.getElementById('filtro-empresa') as HTMLInputElement;

  trigger?.addEventListener('click', () => {
    options?.classList.toggle('active');
    trigger?.classList.toggle('active');
  });

  document.querySelectorAll('.option').forEach(opt => {
    opt.addEventListener('click', () => {
      const val = (opt as HTMLElement).dataset.value || '';
      const label = (opt as HTMLElement).innerText;
      if (hiddenInput) hiddenInput.value = val;
      const labelEl = document.getElementById('selected-company-label');
      if (labelEl) labelEl.innerText = label;
      document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      options?.classList.remove('active');
      trigger?.classList.remove('active');
      cargarHoy();
    });
  });

  window.addEventListener('click', (e) => {
    if (!trigger?.contains(e.target as Node) && !options?.contains(e.target as Node)) {
      options?.classList.remove('active');
      trigger?.classList.remove('active');
    }
  });

  async function cargarHoy() {
    const search = (document.getElementById("empleado-search") as HTMLInputElement)?.value || "";
    const empresa = (document.getElementById("filtro-empresa") as HTMLInputElement)?.value || "";
    
    const res = await fetch(`/api/daily.php?search=${encodeURIComponent(search)}&company=${encodeURIComponent(empresa)}`);
    const data = await res.json();
    
    const cuerpo = document.getElementById("tabla-cuerpo");
    if (cuerpo) {
      if (data.length === 0) {
        cuerpo.innerHTML = '<tr><td colspan="7" class="sin-registros">No hay registros el día de hoy.</td></tr>';
      } else {
        cuerpo.innerHTML = data.map(row => `
          <tr>
            <td class="nombre">${row.full_name}</td>
            <td>${row.entrada ? new Date(row.entrada).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : "-"}</td>
            <td>${row.salida ? new Date(row.salida).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : "-"}</td>
            <td style="font-size: 0.8rem; color: #64748b;">${row.entrada_estacion || "-"}</td>
            <td style="font-size: 0.8rem; color: #64748b;">${row.salida ? (row.salida_estacion || "-") : "-"}</td>
            <td>
              <span class="badge-status ${row.salida ? 'completado' : 'pendiente'}">
                ${row.salida ? "Completado" : "En Turno"}
              </span>
            </td>
            <td>
              <span class="badge-puntualidad ${row.puntualidad.toLowerCase().replace(' ', '-')}">
                ${row.puntualidad}
              </span>
            </td>
          </tr>
        `).join("");
      }
    }
  }

  document.addEventListener("DOMContentLoaded", cargarHoy);
  document.getElementById("btn-buscar")?.addEventListener("click", cargarHoy);

  // Buscar al presionar Enter en el input
  document.getElementById("empleado-search")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      cargarHoy();
    }
  });

  // Lógica para limpiar filtros
  document.getElementById("btn-limpiar")?.addEventListener("click", () => {
    (document.getElementById("empleado-search") as HTMLInputElement).value = "";
    seleccionarEmpresa(""); // Resetear a "Todas"
    cargarHoy(); // Buscar automáticamente tras limpiar
  });
</script>

<style>
  .contenedor-principal { padding: 3rem 1.5rem; max-width: 98%; margin: 0 auto; display: flex; justify-content: center; }
  .daily-card { width: 100%; max-width: 100%; text-align: center; display: flex; flex-direction: column; align-items: center; padding: 3.5rem !important; position: relative; }
  
  .titulo-principal {
    background: linear-gradient(to right, #273469 0%, #4A90E2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 900;
    font-size: 3.2rem;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-bottom: 3.5rem;
    width: 100%;
  }

  .filtros-seccion { width: 100%; margin-bottom: 3rem; }
  
  .filtros-grid { 
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem; 
    align-items: flex-end; 
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
  }

  .input-group { display: flex; flex-direction: column; gap: 8px; text-align: left; }
  .input-group label { font-size: 0.85rem; font-weight: 800; color: #273469; }
  .input-premium { 
    width: 100%;
    padding: 11px 14px; 
    border: 2px solid #e2e8f0; 
    border-radius: 12px; 
    font-size: 0.95rem; 
    background: #f8fafc; 
    font-family: 'Inter', sans-serif;
    box-sizing: border-box;
  }

  /* Custom Select Styles */
  :global(.custom-select-wrapper) { position: relative; width: 100%; }
  :global(.custom-select-trigger) { 
    width: 100%; padding: 11px 14px; border: 2px solid #e2e8f0; border-radius: 12px;
    background: #f8fafc; cursor: pointer; display: flex; justify-content: space-between; 
    align-items: center; font-weight: 500; font-size: 0.95rem; color: #1e293b;
    box-sizing: border-box;
  }
  :global(.custom-select-trigger.active) { border-color: #4a90e2; background: white; }
  :global(.custom-select-trigger.active .arrow) { transform: rotate(180deg); }
  :global(.custom-select-trigger .arrow) { transition: transform 0.3s; color: #94a3b8; }
  :global(.custom-options) { 
    position: absolute; top: calc(100% + 5px); left: 0; right: 0; background: white; 
    border: 2px solid #e2e8f0; border-radius: 12px; z-index: 100; display: none; 
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); overflow: hidden;
    width: 100%;
  }
  :global(.custom-options.active) { display: block; }
  :global(.option) { padding: 10px 14px; cursor: pointer; font-size: 0.9rem; color: #475569; text-align: left; }
  :global(.option:hover) { background: #f1f5f9; color: #4a90e2; }
  :global(.option.selected) { background: #eff6ff; color: #4a90e2; font-weight: 700; }

  .button-group { align-items: stretch; }
  .btn-premium { height: 48px; border-radius: 12px; font-weight: 800; cursor: pointer; transition: all 0.2s; border: none; }
  .btn-premium.primary { background: #4a90e2; color: white; box-shadow: 0 4px 12px rgba(74, 144, 226, 0.3); }
  .btn-premium.outline { background: white; color: #64748b; border: 2px solid #e2e8f0; }

  .tabla-container { width: 100%; border: 1px solid #e2e8f0; border-radius: 20px; overflow: hidden; margin-bottom: 2.5rem; background: #f8fafc; }
  table { width: 100%; border-collapse: collapse; }
  th { background: #f1f5f9; padding: 1.25rem; text-align: center; font-size: 0.75rem; font-weight: 800; color: #475569; }
  td { padding: 1.5rem 1.25rem; border-top: 1px solid #e2e8f0; text-align: center; font-size: 1rem; }
  tr { transition: background 0.2s; }
  tr:hover { background: #f8fafc; }
  .nombre { font-weight: 700; color: #1e293b; }
  .sin-registros { 
    text-align: center; 
    color: #94a3b8; 
    padding: 5rem 1rem; 
    font-style: italic; 
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* Badges */
  :global(.badge-status), :global(.badge-puntualidad) { font-size: 0.65rem; font-weight: 900; padding: 6px 12px; border-radius: 6px; text-transform: uppercase; display: inline-block; }
  :global(.badge-status.completado) { background: #e1fdec !important; color: #065f46 !important; border: 1px solid #34d399; }
  :global(.badge-status.pendiente) { background: #fff9db !important; color: #92400e !important; border: 1px solid #fbbf24; }
  :global(.badge-puntualidad.a-tiempo) { background: #ecfdf5 !important; color: #059669 !important; border: 1px solid #6ee7b7; }
  :global(.badge-puntualidad.retardo) { background: #fffbeb !important; color: #d97706 !important; border: 1px solid #fcd34d; }
  :global(.badge-puntualidad.falta) { background: #fef2f2 !important; color: #dc2626 !important; border: 1px solid #fca5a5; }

  .acciones-footer { width: 100%; display: flex; justify-content: center; }

  /* Responsive Design */
  @media (max-width: 768px) {
    .contenedor-principal { padding: 2rem 1rem; }
    .daily-card { padding: 2rem !important; }
    .titulo-principal { font-size: 2.5rem; margin-bottom: 2rem; }
    .filtros-grid { flex-direction: row; justify-content: center; }
    .input-group { width: 45% !important; }
    .button-group { width: 100% !important; justify-content: center; }
    th:nth-child(4), td:nth-child(4) { display: none; } /* Ocultar Estado en tablet */
  }

  @media (max-width: 425px) {
    .contenedor-principal { padding: 1rem 0.5rem; }
    .daily-card { 
      padding: 1.5rem !important; 
      border-radius: 16px; 
      margin-top: -1.5rem; /* Subir la tarjeta */
    }
    .titulo-principal { font-size: 2rem; margin-bottom: 1.5rem; text-align: left; width: 100%; }
    .filtros-grid { flex-direction: column; align-items: stretch; }
    .input-group { width: 100% !important; }
    .button-group { width: 100% !important; }
    
    .tabla-container { border-radius: 12px; margin-bottom: 1.5rem; }
    th { padding: 0.8rem 0.5rem; font-size: 0.7rem; }
    td { padding: 1rem 0.5rem; font-size: 0.85rem; }
    th:nth-child(5), td:nth-child(5) { display: none; } /* Ocultar Puntualidad en móvil pequeño */
  }

  @media (max-width: 375px) {
    .daily-card { padding: 1rem !important; margin-top: -2rem; }
    .titulo-principal { font-size: 1.8rem; }
    th:nth-child(3), td:nth-child(3) { display: none; } /* Ocultar Salida en móvil muy pequeño */
  }

  @media (max-width: 320px) {
    .contenedor-principal { padding: 0.5rem 0.25rem; }
    .daily-card { padding: 0.8rem !important; margin-top: -2.5rem; }
    .titulo-principal { font-size: 1.6rem; margin-bottom: 1rem; }
    td { font-size: 0.8rem; }
    .btn-premium { height: 44px; font-size: 0.9rem; }
  }
</style>
