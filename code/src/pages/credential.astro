---
import Layout from "../layouts/Layout.astro";
import pool from "../lib/db";

// Verificar sesión del empleado
const session = Astro.cookies.get("session");
if (!session) {
  return Astro.redirect("/");
}

let employee = null;
const userId = session.value.replace("user-", "");

try {
  const [rows] = (await pool.execute(
    "SELECT * FROM users WHERE (id = ? OR employee_id = ?)",
    [userId, userId]
  )) as [any[], any];

  if (rows.length > 0) {
    employee = rows[0];
  }
} catch (e) {
  console.error(e);
}

if (!employee) {
  return Astro.redirect("/");
}

// Determinar el logo según la empresa
const logoSrc = employee.company?.toLowerCase() === 'innova' ? '/empresas/innova.png' : '/empresas/einsur.png';
---

<Layout title="Mi Credencial Digital" hideNavbar={true}>
  <main class="credential-container">
    <div class="pvc-card">
      {/* Cabecera con Ondas */}
      <div class="card-header-v3">
        <svg viewBox="0 0 500 100" preserveAspectRatio="none" class="header-svg">
          <path d="M0,0 L500,0 L500,60 Q250,90 0,60 Z" fill="#273469"></path>
          <path d="M0,60 Q250,90 500,60 L500,75 Q250,105 0,75 Z" fill="#FFD700"></path>
        </svg>
      </div>
      
      <div class="card-content">
        <div class="logo-section">
          <img src={logoSrc} alt={employee.company} class="company-logo" />
        </div>

        <div class="profile-section">
          <div class="photo-container">
            {employee.photo_url ? (
              <img src={employee.photo_url} alt={employee.full_name} class="profile-photo" />
            ) : (
              <div class="photo-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              </div>
            )}
          </div>
          <h2 class="employee-name">{employee.full_name}</h2>
        </div>

        <div class="details-row">
          <div class="info-left">
            <div class="info-item">
              <span class="label">ID EMPLEADO</span>
              <span class="value">{employee.employee_id}</span>
            </div>
            <div class="info-item">
              <span class="label">DEPARTAMENTO</span>
              <span class="value">{employee.department}</span>
            </div>
          </div>
          
          <div class="info-right">
            <div id="qrcode-container" class="qr-container">
              {/* QR Dinámico */}
            </div>
          </div>
        </div>
      </div>

      {/* Pie de Página con Ondas */}
      <div class="card-footer-v3">
        <svg viewBox="0 0 500 100" preserveAspectRatio="none" class="footer-svg">
          <path d="M0,40 Q250,0 500,40 L500,55 Q250,15 0,55 Z" fill="#FFD700"></path>
          <path d="M0,55 Q250,15 500,55 L500,100 L0,100 Z" fill="#273469"></path>
        </svg>
      </div>

      <div class="actions">
        <button id="btn-logout" class="logout-link">Cerrar Sesión</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-ignore
  import QRCode from "qrcode";

  async function generateQR() {
    try {
      const res = await fetch("/api/generate-qr");
      const data = await res.json();

      if (data.qrCode) {
        const container = document.getElementById("qrcode-container");
        if (container) {
          container.innerHTML = "";
          const canvas = document.createElement("canvas");
          await QRCode.toCanvas(canvas, data.qrCode, {
            width: 115,
            margin: 0,
            color: { dark: "#273469", light: "#ffffff" },
          });
          container.appendChild(canvas);
        }
      }
    } catch (e) {
      console.error("Error QR:", e);
    }
  }

  generateQR();
  setInterval(generateQR, 10000);

  document.getElementById("btn-logout")?.addEventListener("click", async () => {
    await fetch("/api/logout", { method: "POST" });
    window.location.href = "/";
  });
</script>

<style>
  .credential-container {
    min-height: 100vh;
    background-color: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    font-family: 'Inter', sans-serif;
  }

  .pvc-card {
    width: 400px;
    height: 720px;
    background: white;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.4);
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 8px;
  }

  .card-header-v3 {
    width: 100%;
    height: 90px;
    flex-shrink: 0;
  }
  .header-svg { width: 100%; height: 100%; display: block; }

  .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
    overflow: hidden;
  }

  .logo-section {
    margin-top: 5px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .company-logo {
    max-height: 60px;
    max-width: 250px;
    object-fit: contain;
  }

  .profile-section {
    text-align: center;
    margin: 10px 0;
    flex-shrink: 0;
  }
  .photo-container {
    width: 190px;
    height: 230px;
    background: #f8fafc;
    margin: 0 auto 0.8rem;
    border: 2px solid #273469;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 2px;
  }
  .profile-photo { width: 100%; height: 100%; object-fit: cover; }
  .employee-name {
    font-size: 1.6rem;
    font-weight: 900;
    color: #1e293b;
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .details-row {
    margin-top: auto;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 5px;
  }

  .info-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .info-item .label {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
    font-weight: 800;
  }
  .info-item .value {
    font-weight: 700;
    color: #273469;
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .info-right {
    width: 115px;
    height: 115px;
  }
  .qr-container { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .qr-container :global(canvas) { width: 100% !important; height: 100% !important; }

  .card-footer-v3 {
    width: 100%;
    height: 110px;
    position: relative;
    flex-shrink: 0;
  }
  .footer-svg { width: 100%; height: 100%; display: block; }
  .actions {
    position: absolute;
    bottom: -50px;
    width: 100%;
    text-align: center;
  }
  .logout-link {
    background: none;
    border: none;
    color: #64748b;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: underline;
  }

  @media (max-width: 450px) {
    .pvc-card { width: 100%; height: 100vh; border-radius: 0; box-shadow: none; }
    .card-footer-v3 { height: 130px; }
  }
</style>
