---
import Layout from "../layouts/Layout.astro";
import pool from "../lib/db";

// Verificar sesión del empleado
const session = Astro.cookies.get("employee_session");
if (!session) {
  return Astro.redirect("/");
}

let employee = null;
const employee_id = session.value;

try {
  // Corregimos el aviso de 'rows' diciéndole que es una lista [any[], any]
  const [rows] = (await pool.execute(
    "SELECT * FROM users WHERE (id = ? OR employee_id = ?)",
    [employee_id, employee_id]
  )) as [any[], any];

  if (rows.length > 0) {
    employee = rows[0];
  }
} catch (e) {
  console.error(e);
}

if (!employee) {
  return Astro.redirect("/");
}
---

<Layout title="Mi Credencial Digital" hideNavbar={true}>
  <main class="credential-container">
    <div class="pvc-card">
      {/* Franja Superior Amarilla */}
      <div class="top-stripe yellow"></div>
      
      <div class="card-content">
        <div class="header">
          <div class="logo-container">
            {employee.company === 'Innova' ? (
              <div class="logo-placeholder">INNOVA</div>
            ) : (
              <img src="/empresas/einsur.png" alt="Einsur" class="company-logo" />
            )}
          </div>
          <div class="id-badge">ID: {employee.employee_id}</div>
        </div>

        <div class="profile-section">
          <div class="photo-container">
            <div class="photo-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
          </div>
          <h2 class="employee-name">{employee.full_name}</h2>
          <p class="employee-position">Personal Operativo</p>
        </div>

        <div class="bottom-info">
          <div class="info-details">
            <div class="info-item">
              <span class="label">DEPARTAMENTO</span>
              <span class="value">{employee.department}</span>
            </div>
            <div class="info-item">
              <span class="label">EMPLEADO ID</span>
              <span class="value">{employee.employee_id}</span>
            </div>
          </div>
          <div class="qr-section">
            <div id="qrcode-container" class="qr-container">
              {/* QR Dinámico */}
            </div>
          </div>
        </div>

        {/* Pie de Página con Franjas */}
        <div class="footer-waves">
          <div class="wave-bottom yellow"></div>
          <div class="wave-bottom blue"></div>
        </div>
      </div>

      <div class="actions">
        <button id="btn-logout" class="logout-link">Cerrar Sesión</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-ignore - Evita el aviso de falta de tipos en el editor
  import QRCode from "qrcode";

  async function generateQR() {
    try {
      const res = await fetch("/api/generate-qr");
      const data = await res.json();

      if (data.qrCode) {
        const container = document.getElementById("qrcode-container");
        if (container) {
          container.innerHTML = "";
          const canvas = document.createElement("canvas");
          await QRCode.toCanvas(canvas, data.qrCode, {
            width: 140,
            margin: 1,
            color: { dark: "#273469", light: "#ffffff" },
          });
          container.appendChild(canvas);
        }
      }
    } catch (e) {
      console.error("Error QR:", e);
    }
  }

  generateQR();
  setInterval(generateQR, 10000);

  document.getElementById("btn-logout")?.addEventListener("click", async () => {
    await fetch("/api/logout", { method: "POST" });
    window.location.href = "/";
  });
</script>

<style>
  .credential-container {
    min-height: 100vh;
    background-color: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    font-family: 'Inter', sans-serif;
  }

  .pvc-card {
    width: 350px;
    height: 580px;
    background: white;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .top-stripe { height: 12px; width: 100%; }
  .top-stripe.yellow { background-color: #FFD700; }

  .card-content { flex: 1; padding: 1.5rem; display: flex; flex-direction: column; position: relative; }

  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .logo-placeholder { font-weight: 900; color: #273469; font-size: 1.2rem; letter-spacing: 1px; }
  .company-logo { height: 60px; object-fit: contain; margin-top: 10px; }
  .id-badge { background: #f1f5f9; padding: 4px 10px; font-size: 0.7rem; font-weight: 800; color: #475569; }

  .profile-section { text-align: center; margin-bottom: 2rem; }
  .photo-container {
    width: 160px; height: 180px; background: #f8fafc; margin: 0 auto 1.2rem;
    border: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: center;
  }
  .photo-placeholder { opacity: 0.5; }
  .employee-name { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin: 0; line-height: 1.2; text-transform: uppercase; }
  .employee-position { color: #64748b; font-size: 0.85rem; font-weight: 600; margin-top: 5px; }

  .bottom-info { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; padding-bottom: 2rem; }
  .info-details { flex: 1; }
  .info-item { margin-bottom: 12px; }
  .info-item .label { display: block; font-size: 0.6rem; color: #94a3b8; font-weight: 800; letter-spacing: 1px; margin-bottom: 2px; }
  .info-item .value { font-weight: 700; color: #273469; font-size: 0.95rem; }

  .qr-section { width: 130px; height: 130px; display: flex; align-items: center; justify-content: center; }
  .qr-container { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .qr-container :global(canvas) { width: 100% !important; height: 100% !important; }

  .footer-waves { position: absolute; bottom: 0; left: 0; right: 0; height: 30px; }
  .wave-bottom { height: 100%; width: 100%; position: absolute; bottom: 0; }
  .wave-bottom.blue { background-color: #273469; clip-path: polygon(0 40%, 100% 0, 100% 100%, 0% 100%); }
  .wave-bottom.yellow { background-color: #FFD700; clip-path: polygon(0 0, 100% 40%, 100% 100%, 0% 100%); bottom: 5px; }

  .actions { position: absolute; bottom: -60px; width: 100%; text-align: center; }
  .logout-link { background: none; border: none; color: #64748b; font-weight: 700; font-size: 0.8rem; cursor: pointer; text-decoration: underline; }
  .logout-link:hover { color: #1e293b; }
</style>
