---
import Layout from "../layouts/Layout.astro";
---

<script>
  // Verificar sesión y cargar datos
  async function init() {
    if (
      !document.cookie
        .split(";")
        .some((item) => item.trim().startsWith("session="))
    ) {
      window.location.replace("/");
      return;
    }

    try {
      const res = await fetch("/api/me.php");
      if (!res.ok) throw new Error("No session");
      const employee = await res.json();

      // Rellenar datos
      document.getElementById("employee-name").textContent = employee.full_name;
      document.getElementById("employee-puesto").textContent =
        employee.puesto || "Empleado";
      document.getElementById("employee-id").textContent = employee.employee_id;
      document.getElementById("employee-dept").textContent =
        employee.department;

      const logoImg = document.getElementById(
        "company-logo",
      ) as HTMLImageElement;

      const cardEl = document.querySelector(".pvc-card") as HTMLElement;
      const companyLower = employee.company?.toLowerCase() || "";
      if (companyLower === "innova") {
        logoImg.src = "/empresas/innova.png";
        logoImg.style.maxHeight = "60px";
        if (cardEl) {
          cardEl.style.setProperty("--card-primary-color", "#273469");
          cardEl.style.setProperty("--card-accent-color", "#FFD700");
        }
      } else if (
        companyLower === "cafe valentina" ||
        companyLower === "café valentina"
      ) {
        logoImg.src = "/empresas/cafe_valentina.png";
        // Al ser un logo con formato más vertical/cuadrado, incrementamos su max-height
        // a 80px para que se aprecie perfectamente sin encimarse con la foto.
        logoImg.style.maxHeight = "80px";
        if (cardEl) {
          // Colores de Café Valentina solicitados: café/chocolate y caramelo
          cardEl.style.setProperty("--card-primary-color", "#5c3d2e");
          cardEl.style.setProperty("--card-accent-color", "#bf8858");
        }
      } else if (companyLower === "prosime") {
        logoImg.src = "/empresas/prosime.png";
        logoImg.style.maxHeight = "60px";
        if (cardEl) {
          cardEl.style.setProperty("--card-primary-color", "#273469");
          cardEl.style.setProperty("--card-accent-color", "#FFD700");
        }
      } else if (companyLower === "la casita") {
        logoImg.src = "/empresas/lacasita.png";
        logoImg.style.maxHeight = "60px";
        if (cardEl) {
          cardEl.style.setProperty("--card-primary-color", "#166534");
          cardEl.style.setProperty("--card-accent-color", "#ea580c");
        }
      } else {
        logoImg.src = "/empresas/einsur.png";
        logoImg.style.maxHeight = "60px";
        if (cardEl) {
          cardEl.style.setProperty("--card-primary-color", "#273469");
          cardEl.style.setProperty("--card-accent-color", "#FFD700");
        }
      }
      logoImg.alt = employee.company;

      // Lógica de Foto: Prioridad DB > Carpeta /fotos/ > Placeholder
      const photoContainer = document.getElementById("photo-container");
      const photoPath =
        employee.photo_url || `/fotos/${employee.employee_id}.jpg`;

      if (photoContainer) {
        photoContainer.innerHTML = `
          <img 
            src="${photoPath}" 
            alt="${employee.full_name}" 
            class="profile-photo" 
            onerror="this.style.display='none'; document.getElementById('photo-placeholder').style.display='flex';"
            onload="document.getElementById('photo-placeholder').style.display='none'; this.style.display='block';"
            style="display: none; width: 100%; height: 100%; object-fit: cover; border-radius: 0;"
          />
          <div id="photo-placeholder" class="photo-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
        `;
      }
    } catch (e) {
      window.location.replace("/");
    }
  }

  init();
</script>

<Layout title="Mi Credencial Digital" hideNavbar={true}>
  <main class="credential-container">
    <div class="card-wrapper">
      <div class="pvc-card">
        {/* Cabecera con Ondas */}
        <div class="card-header-v3">
          <svg
            viewBox="0 0 500 100"
            preserveAspectRatio="none"
            class="header-svg"
          >
            <path
              d="M0,0 L500,0 L500,60 Q250,90 0,60 Z"
              fill="var(--card-primary-color, #273469)"></path>
            <path
              d="M0,60 Q250,90 500,60 L500,75 Q250,105 0,75 Z"
              fill="var(--card-accent-color, #FFD700)"></path>
          </svg>
        </div>

        <div class="card-content">
          <div class="logo-section">
            <img id="company-logo" src="" alt="" class="company-logo" />
          </div>

          <div class="profile-section">
            <div class="photo-container" id="photo-container">
              <div class="photo-placeholder">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="60"
                  height="60"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#cbd5e1"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                  ></path><circle cx="12" cy="7" r="4"></circle>
                </svg>
              </div>
            </div>
            <h2 id="employee-name" class="employee-name">...</h2>
            <p id="employee-puesto" class="employee-puesto">...</p>
          </div>

          <div class="details-row">
            <div class="info-left">
              <div class="info-item">
                <span class="label">ID EMPLEADO</span>
                <span id="employee-id" class="value">...</span>
              </div>
              <div class="info-item">
                <span class="label">DEPARTAMENTO</span>
                <span id="employee-dept" class="value">...</span>
              </div>
            </div>

            <div class="info-right">
              <div id="qrcode-container" class="qr-container">
                {/* QR Dinámico */}
              </div>
            </div>
          </div>
        </div>

        {/* Pie de Página con Ondas */}
        <div class="card-footer-v3">
          <svg
            viewBox="0 0 500 100"
            preserveAspectRatio="none"
            class="footer-svg"
          >
            <path
              d="M0,40 Q250,0 500,40 L500,55 Q250,15 0,55 Z"
              fill="var(--card-accent-color, #FFD700)"></path>
            <path
              d="M0,55 Q250,15 500,55 L500,100 L0,100 Z"
              fill="var(--card-primary-color, #273469)"></path>
          </svg>
        </div>
      </div>

      <div class="actions">
        <button id="btn-logout" class="btn-logout-premium">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline
              points="16 17 21 12 16 7"></polyline><line
              x1="21"
              y1="12"
              x2="9"
              y2="12"></line>
          </svg>
          Cerrar Sesión
        </button>
      </div>

      {/* Modal de Confirmación de Logout */}
      <div id="logout-confirm-modal" class="modal">
        <div class="modal-content card-premium">
          <div class="logout-icon-circle">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
              ></path><polyline points="16 17 21 12 16 7"></polyline><line
                x1="21"
                y1="12"
                x2="9"
                y2="12"></line>
            </svg>
          </div>
          <h2>¿Cerrar Sesión?</h2>
          <p>
            Tendrás que ingresar tus credenciales la próxima vez que quieras
            acceder.
          </p>
          <div class="confirm-actions">
            <button
              type="button"
              id="cancel-logout"
              class="btn-modal-action outline">No, volver</button
            >
            <button
              type="button"
              id="confirm-logout"
              class="btn-modal-action primary danger">Sí, salir</button
            >
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-ignore
  import QRCode from "qrcode";

  async function generateQR() {
    try {
      const res = await fetch("/api/generate-qr.php");
      const data = await res.json();

      if (data.qrCode) {
        const container = document.getElementById("qrcode-container");
        if (container) {
          container.innerHTML = "";
          const canvas = document.createElement("canvas");
          const cardEl = document.querySelector(".pvc-card") as HTMLElement;
          const qrDark =
            cardEl?.style.getPropertyValue("--card-primary-color")?.trim() ||
            "#273469";
          await QRCode.toCanvas(canvas, data.qrCode, {
            scale: 10,
            margin: 0,
            color: { dark: qrDark, light: "#ffffff" },
          });
          container.appendChild(canvas);
        }
      }
    } catch (e) {
      console.error("Error QR:", e);
    }
  }

  generateQR();
  setInterval(generateQR, 5000);

  const logoutModal = document.getElementById("logout-confirm-modal");

  document.getElementById("btn-logout")?.addEventListener("click", () => {
    logoutModal?.classList.add("active");
  });

  document.getElementById("cancel-logout")?.addEventListener("click", () => {
    logoutModal?.classList.remove("active");
  });

  document
    .getElementById("confirm-logout")
    ?.addEventListener("click", async () => {
      await fetch("/api/logout.php", { method: "POST" });
      window.location.replace("/");
    });

  // Bloqueo de flecha atrás
  window.history.pushState(null, "", window.location.href);
  window.onpopstate = function () {
    window.history.pushState(null, "", window.location.href);
  };

  // Cerrar modal al clickear fuera
  window.addEventListener("click", (e) => {
    if (e.target === logoutModal) {
      logoutModal?.classList.remove("active");
    }
  });
</script>

<style>
  .credential-container {
    min-height: 100vh;
    background-color: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    font-family: "Inter", sans-serif;
  }

  .card-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .pvc-card {
    width: 400px;
    height: auto;
    min-height: 760px;
    background: white;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.4);
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-header-v3 {
    width: 100%;
    height: 90px;
    flex-shrink: 0;
  }
  .header-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
  }

  .logo-section {
    margin-top: 5px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .company-logo {
    max-height: 60px;
    max-width: 250px;
    object-fit: contain;
  }

  .profile-section {
    text-align: center;
    margin: 10px 0;
    flex-shrink: 0;
  }
  .photo-container {
    width: 190px;
    height: 230px;
    background: #f8fafc;
    margin: 0 auto 0.8rem;
    border: 2px solid var(--card-primary-color, #273469);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 2px;
  }
  .profile-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .employee-name {
    font-size: 1.6rem;
    font-weight: 900;
    color: #1e293b;
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
  }
  .employee-puesto {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--card-primary-color, #4a90e2);
    margin: 4px 0 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .details-row {
    margin-top: auto;
    margin-bottom: 0px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 5px;
  }

  .info-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .info-item .label {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
    font-weight: 800;
  }
  .info-item .value {
    font-weight: 700;
    color: var(--card-primary-color, #273469);
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .info-right {
    width: 115px;
    height: 115px;
    flex-shrink: 0;
  }
  .qr-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qr-container :global(canvas) {
    width: 100% !important;
    height: 100% !important;
  }

  .card-footer-v3 {
    width: 100%;
    height: 110px;
    position: relative;
    flex-shrink: 0;
  }
  .footer-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .actions {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-logout-premium {
    background: #ffffff;
    border: 2px solid #e2e8f0;
    color: #64748b;
    padding: 12px 32px;
    border-radius: 14px;
    font-weight: 800;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .btn-logout-premium:hover {
    background: #fef2f2;
    color: #ef4444;
    border-color: #fee2e2;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.1);
  }

  @media (max-width: 450px) {
    .credential-container {
      padding: 1rem;
      align-items: flex-start;
      padding-top: 5vh;
    }
    .pvc-card {
      width: 100%;
      height: auto;
      min-height: 760px;
      border-radius: 0;
      box-shadow: none;
    }
    .card-footer-v3 {
      height: 130px;
    }
    .card-wrapper {
      gap: 1rem;
      padding-bottom: 2rem;
      width: 100%;
    }
    .btn-logout-premium {
      width: 90%;
    }
  }

  /* Modal Styles */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.7);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    z-index: 2000;
    padding: 1.5rem;
  }
  .modal.active {
    display: flex;
  }
  .modal-content {
    background: white;
    width: 100%;
    max-width: 400px;
    padding: 3rem;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
  .logout-icon-circle {
    width: 64px;
    height: 64px;
    background: #fef2f2;
    color: #ef4444;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .modal-content h2 {
    font-weight: 900;
    font-size: 1.5rem;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .modal-content p {
    color: #64748b;
    font-weight: 500;
    line-height: 1.5;
    margin-bottom: 2rem;
  }
  .confirm-actions {
    display: flex;
    gap: 1rem;
  }
  .btn-modal-action {
    flex: 1;
    padding: 12px;
    border-radius: 12px;
    font-weight: 800;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }
  .btn-modal-action.outline {
    background: #f8fafc;
    color: #64748b;
    border: 2px solid #e2e8f0;
  }
  .btn-modal-action.primary.danger {
    background: #ef4444;
    color: white;
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
  }
  .btn-modal-action:hover {
    transform: translateY(-2px);
  }
</style>
