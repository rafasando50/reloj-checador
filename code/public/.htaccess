RewriteEngine On
RewriteBase /

# Solo una regla: si pides /admin/login y no existe como archivo, 
# pero existe admin/login.html, úsalo internamente sin cambiar la URL.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
